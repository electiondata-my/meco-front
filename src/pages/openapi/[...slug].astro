---
import DocLayout from "@src/components/OpenApi/DocLayout.astro";
import { mdxComponents } from "@src/components/OpenApi/mdxComponents";
import PreCodeBlock from "@src/components/OpenApi/mdx/PreCodeBlock.astro";
import OrderedList from "@src/components/OpenApi/mdx/OrderedList.astro";
import TabCodeIsland from "@src/components/OpenApi/mdx/TabCodeIsland.astro";
import TokenInputIsland from "@src/components/OpenApi/mdx/TokenInputIsland.astro";
import CandidatesApiTesterIsland from "@src/components/OpenApi/mdx/CandidatesApiTesterIsland.astro";
import ResultsApiTesterIsland from "@src/components/OpenApi/mdx/ResultsApiTesterIsland.astro";
import ByelectionApiTesterIsland from "@src/components/OpenApi/mdx/ByelectionApiTesterIsland.astro";
import UnorderedList from "@src/components/OpenApi/mdx/UnorderedList.astro";
import { getCollection, render } from "astro:content";
import { extractToc } from "@src/lib/docs";

export async function getStaticPaths() {
  const scope = import.meta.env.POST_TO_BUILD_OPENAPI;
  const anyScope = !!(
    scope ||
    import.meta.env.POST_TO_BUILD ||
    import.meta.env.POST_TO_BUILD_CANDIDATES ||
    import.meta.env.POST_TO_BUILD_CATALOGUE ||
    import.meta.env.POST_TO_BUILD_ELECTIONS ||
    import.meta.env.POST_TO_BUILD_PARTIES ||
    import.meta.env.POST_TO_BUILD_SEATS
  );
  if (anyScope && !scope) return [];
  const slugFilter = scope && scope !== "all" ? new Set(scope.split(",")) : null;

  const entries = await getCollection("openapi");
  return entries
    .filter(e => e.id !== "introduction")
    .filter(e => !slugFilter || slugFilter.has(e.id))
    .map(entry => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const toc = extractToc(entry.body ?? "");
const { title, pageTitle, breadcrumb, description } = entry.data;

// Build the current path from the slug.
// e.g. entry.id "authentication" → "/openapi/authentication"
//      entry.id "endpoints/candidates" → "/openapi/endpoints/candidates"
const currentPath = `/openapi/${entry.id}`;
---

<DocLayout
  title={title}
  pageTitle={pageTitle}
  description={description}
  breadcrumb={breadcrumb}
  toc={toc}
  currentPath={currentPath}
>
  <Content components={{ ...mdxComponents, pre: PreCodeBlock, ol: OrderedList, ul: UnorderedList, TabCode: TabCodeIsland, TokenInput: TokenInputIsland, CandidatesApiTester: CandidatesApiTesterIsland, ApiTester: CandidatesApiTesterIsland, ResultsApiTester: ResultsApiTesterIsland, ByelectionApiTester: ByelectionApiTesterIsland }} />
</DocLayout>
