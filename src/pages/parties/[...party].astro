---
// STUB — restore real implementation from commit cd1529011c0440204a61dafadb88f3b435b3f08c
// git show cd1529011c0440204a61dafadb88f3b435b3f08c:src/pages/parties/[...party].astro
import Layout from "@src/components/Layout/index.astro";
import { fetchJSON } from "@src/lib/api";
import { MALAYSIA, STATES } from "@src/lib/constants";

type DropdownEntry = {
  party_uid: string;
  party: string;
  party_name_en: string;
  party_name_bm: string;
  type: string;
};

export async function getStaticPaths() {
  const scope      = import.meta.env.POST_TO_BUILD_PARTIES;
  const anyScope   = !!(import.meta.env.POST_TO_BUILD_CANDIDATES || import.meta.env.POST_TO_BUILD_ELECTIONS || scope);
  if (anyScope && !scope) return [];
  const slugFilter = scope && scope !== 'all' ? new Set(scope.split(',')) : null;

  let entries: DropdownEntry[] = [];
  try {
    const json = await fetchJSON<{ data: DropdownEntry[] }>("/parties/dropdown.json");
    entries = json.data ?? [];
  } catch { /* non-fatal */ }

  const stateCodes = [MALAYSIA.key, ...STATES.map(s => s.key)];

  return entries.flatMap(e =>
    stateCodes
      .filter(() => !slugFilter || slugFilter.has(e.party_uid))
      .map(stateCode => ({
        params: { party: `${e.party_uid}/${stateCode}` },
        props:  { partyUid: e.party_uid, stateCode },
      }))
  );
}

const { partyUid, stateCode } = Astro.props as { partyUid: string; stateCode: string };
---

<Layout title="Parties — Coming Soon">
  <div class="mx-auto flex max-w-screen-xl flex-col items-center justify-center gap-4 px-4 py-32">
    <h1 class="text-center font-heading text-heading-sm font-semibold text-txt-black-900">
      Coming soon
    </h1>
    <p class="text-center text-body-sm text-txt-black-500">
      {partyUid} / {stateCode}
    </p>
  </div>
</Layout>
