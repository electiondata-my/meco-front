---
import Layout from "@src/components/Layout/index.astro";
import { getTranslations, t } from "@i18n/index";
import { PAPERS } from "@src/data/papers";

const locale = Astro.currentLocale ?? "en-GB";
const i18n = await getTranslations(locale, ["research"]);
const r = (key: string) => t(i18n.research ?? {}, key);
---

<Layout title={r("hero.header")} description={r("hero.description")}>
  <!-- Hero -->
  <section
    class="mx-auto grid h-full w-full grid-cols-4 gap-4.5 bg-gradient-radial from-bg-danger-100 to-bg-white px-4.5 md:grid-cols-8 md:gap-6 md:px-6 lg:grid-cols-12"
  >
    <div
      class="col-span-full mx-auto flex w-full max-w-screen-xl flex-col items-center justify-center xl:w-full"
    >
      <div
        class="flex max-w-[727px] flex-col items-center justify-center space-y-4 pb-8 pt-16 lg:space-y-6"
      >
        <h1
          class="text-center font-poppins text-heading-sm font-semibold text-txt-black-900 lg:text-heading-md"
        >
          {r("hero.header")}
        </h1>
        <p class="w-full whitespace-pre-line text-center text-body-sm text-txt-black-700 lg:text-body-md">
          {r("hero.description")}
        </p>
      </div>
    </div>
  </section>

  <!-- Papers grid -->
  <div
    class="mx-auto grid h-full w-full grid-cols-4 gap-4.5 px-4.5 md:grid-cols-8 md:gap-6 md:px-6 lg:grid-cols-12"
  >
    <div
      class="col-span-full mx-auto flex w-full max-w-screen-xl flex-col items-center justify-center xl:w-full"
    >
      <div class="w-full pb-12 pt-6 lg:pt-8">
        <div class="grid w-full grid-cols-1 gap-4 sm:grid-cols-2 md:grid-cols-4 lg:gap-6">
          {
            PAPERS.map((paper) => {
              const isComingSoon = paper.status === "coming_soon";
              const card = (
                <div
                  class:list={[
                    "group flex h-full flex-col overflow-hidden rounded-xl border border-otl-gray-200 bg-bg-white transition dark:bg-zinc-900",
                    !isComingSoon && "cursor-pointer hover:border-otl-gray-300 hover:shadow-lg",
                    isComingSoon && "opacity-75",
                  ]}
                >
                  <!-- A4 preview -->
                  <div class="relative aspect-[1/0.707] w-full overflow-hidden bg-gray-50 dark:bg-zinc-800 sm:aspect-[1/1.414]">
                    {paper.thumbnail ? (
                      <img
                        src={paper.thumbnail}
                        alt={r(`${paper.key}.title`)}
                        class="h-full w-full object-cover object-top transition group-hover:scale-[1.02]"
                      />
                    ) : (
                      <div class="flex h-full flex-col items-center justify-center gap-3 p-6 text-center">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke-width="1.5"
                          stroke="currentColor"
                          class="size-12 text-gray-300 dark:text-zinc-600"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
                          />
                        </svg>
                        <p class="text-body-sm font-medium text-gray-400 dark:text-zinc-500">
                          {r("coming_soon")}
                        </p>
                      </div>
                    )}
                  </div>
                  <!-- Details -->
                  <div class="flex flex-1 flex-col gap-1.5 p-4">
                    <h3
                      class="font-poppins text-body-sm font-semibold leading-snug text-txt-black-900 lg:text-body-md"
                    >
                      {r(`${paper.key}.title`)}
                    </h3>
                    <p class="text-body-2xs text-txt-black-500 lg:text-body-sm">
                      {r(`${paper.key}.authors`)}
                    </p>
                    <p class="text-body-2xs font-medium italic text-txt-black-700 lg:text-body-sm">
                      {r(`${paper.key}.venue`)}
                    </p>
                  </div>
                </div>
              );

              return paper.url ? (
                <a
                  href={paper.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="no-underline"
                  aria-label={r(`${paper.key}.title`)}
                >
                  {card}
                </a>
              ) : (
                card
              );
            })
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
