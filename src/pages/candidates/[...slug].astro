---
import CandidatePage from "@src/components/Candidates/CandidatePage.astro";
import { fetchJSON } from "@src/lib/api";

type DropdownEntry = { name: string; slug: string; c: string; w: string; l: string };
type CandidateElection = {
  type: "parlimen" | "dun";
  election_name: string;
  date: string;
  seat: string;
  party: string;
  party_uid?: string;
  votes: number;
  votes_perc: number;
  result: string;
};

export async function getStaticPaths() {
  const scope      = import.meta.env.POST_TO_BUILD_CANDIDATES;
  const anyScope   = !!(scope || import.meta.env.POST_TO_BUILD_ELECTIONS || import.meta.env.POST_TO_BUILD_PARTIES || import.meta.env.POST_TO_BUILD_OPENAPI);
  if (anyScope && !scope) return [];
  const slugFilter = scope && scope !== 'all' ? new Set(scope.split(',')) : null;
  const r2 = import.meta.env.PUBLIC_API_URL_R2;

  const [dropdownJson, allData] = await Promise.all([
    fetchJSON<{ data: DropdownEntry[] }>("/candidates/dropdown.json", r2).catch(() => ({ data: [] as DropdownEntry[] })),
    fetchJSON<Record<string, CandidateElection[]>>("/candidates/all.json", r2).catch(() => ({} as Record<string, CandidateElection[]>)),
  ]);

  const dropdown = dropdownJson.data ?? [];

  return dropdown
    .filter(e => !slugFilter || slugFilter.has(e.slug))
    .map(e => ({
      params: { slug: e.slug },
      props: {
        currentOption: { name: e.name, slug: e.slug, w: e.w, l: e.l },
        candData: allData[e.slug] ?? null,
      },
    }));
}

const { slug } = Astro.params as { slug: string };
const { currentOption, candData } = Astro.props as {
  currentOption: { name: string; slug: string; w: string; l: string };
  candData: CandidateElection[] | null;
};
---

<CandidatePage slug={slug} currentOption={currentOption} candData={candData} />
