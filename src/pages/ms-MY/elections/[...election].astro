---
import ElectionsPage from "@src/components/Elections/ElectionsPage.astro";
import { fetchJSON } from "@src/lib/api";
import { StateKeyByName } from "@src/lib/constants";

type ElectionEntry = { state: string; election: string; date: string };
type DatesJson = { data: ElectionEntry[] };

export async function getStaticPaths() {
  const filter = import.meta.env.POST_TO_BUILD;

  let entries: ElectionEntry[] = [];
  try {
    const json = await fetchJSON<DatesJson>("/dates.json");
    entries = json.data ?? [];
  } catch { /* non-fatal */ }

  return entries
    .filter(e => !filter || e.election === filter)
    .flatMap(e => {
      const stateCode = StateKeyByName[e.state];
      if (!stateCode) return [];
      return [{
        params: { election: `${stateCode}/${e.election}` },
        props:  { stateCode, electionName: e.election },
      }];
    });
}

const { stateCode, electionName } = Astro.props as { stateCode: string; electionName: string };
---

<ElectionsPage stateCode={stateCode} electionName={electionName} />
