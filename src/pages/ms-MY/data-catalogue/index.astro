---
import Layout from "@src/components/Layout/index.astro";

const title = "Katalog Data | ElectionData.MY";
const description = "Katalog data ElectionData.MY akan dilancarkan tidak lama lagi.";
---

<Layout title={title} description={description}>
  <main
    class="mx-auto grid min-h-[calc(100vh-4rem)] w-full grid-cols-4 gap-4.5 bg-bg-white px-4.5 py-16 md:grid-cols-8 md:gap-6 md:px-6 lg:grid-cols-12 lg:py-20"
  >
    <section
      class="col-span-full mx-auto flex w-full max-w-screen-xl items-center justify-center xl:w-full"
    >
      <div class="flex w-full max-w-2xl flex-col items-center gap-5 text-center">
        <div
          class="inline-flex items-center rounded-full border border-otl-gray-200 bg-bg-washed px-3 py-1 text-body-xs font-semibold uppercase tracking-[0.1em] text-txt-danger"
        >
          2 Hari Lagi
        </div>
        <h1 class="font-poppins text-heading-sm font-bold text-txt-black-900 lg:text-heading-md">
          Akan Datang
        </h1>
        <p class="max-w-xl text-body-lg leading-8 text-txt-black-600">
          Katalog data hampir siap. Set data pilihan raya berstruktur dan bersih—bersekali dengan metadata komprehensif—akan tersedia di sini tidak lama lagi. Ini akan menjadi sumber utama anda untuk keputusan, sempadan, demografi, dan banyak lagi.
        </p>
 
      </div>
    </section>
  </main>
</Layout>
