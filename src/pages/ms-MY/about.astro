---
import Layout from "@src/components/Layout/index.astro";
import { getEntry, render } from "astro:content";
import { makeArticleComponents } from "@src/components/Article/components";

const locale = Astro.currentLocale ?? "ms-MY";
const entry = await getEntry("articles", `about/${locale.toLowerCase()}`);
if (!entry) return Astro.redirect("/ms-MY");

const { Content } = await render(entry);
const { title, metaTitle, description, principles = [] } = entry.data;
const components = makeArticleComponents(principles);
---

<Layout title={metaTitle ?? title} description={description}>
  <article
    class="mx-auto grid h-full w-full grid-cols-4 gap-4.5 bg-bg-white px-4.5 pb-14 pt-16 md:grid-cols-8 md:gap-6 md:px-6 lg:grid-cols-12 lg:pb-20 lg:pt-20"
  >
    <section
      class="col-span-full mx-auto flex w-full max-w-screen-xl flex-col items-center justify-center xl:w-full"
    >
      <div class="w-full max-w-[640px]">
        <h1
          class="text-center text-[2.25rem] font-normal leading-[1.08] text-txt-black-900 lg:text-[3.125rem]"
          style="font-family: Georgia, 'Times New Roman', serif"
        >
          {title}
        </h1>
      </div>
      <Content components={components} />
    </section>
  </article>
</Layout>
