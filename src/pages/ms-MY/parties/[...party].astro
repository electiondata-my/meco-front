---
import PartyPage from "@src/components/Parties/PartyPage.astro";
import { fetchJSON } from "@src/lib/api";
import { MALAYSIA, SEMENANJUNG, STATES } from "@src/lib/constants";

type DropdownEntry = {
  uid: string;
  maps_to: string;
  acronym: string;
  name_en: string;
  name_bm: string;
  type: string;
};
type PartyElection = {
  party_type: string;
  state: string;
  type: "parlimen" | "dun";
  coalition?: string;
  coalition_uid?: string;
  election_name: string;
  date: string;
  seats_total: number;
  seats_contested: number;
  seats_contested_perc: number;
  seats_won: number;
  seats_won_perc: number;
  votes: number;
  votes_perc: number;
};

export async function getStaticPaths() {
  const scope    = import.meta.env.POST_TO_BUILD_PARTIES;
  const anyScope = !!(scope || import.meta.env.POST_TO_BUILD_CANDIDATES || import.meta.env.POST_TO_BUILD_ELECTIONS || import.meta.env.POST_TO_BUILD_SEATS || import.meta.env.POST_TO_BUILD_CATALOGUE || import.meta.env.POST_TO_BUILD_OPENAPI);
  if (anyScope && !scope) return [];
  const slugFilter = scope && scope !== "all" ? new Set(scope.split(",")) : null;
  const r2 = import.meta.env.PUBLIC_API_URL_R2;

  const [dropdownJson, allData] = await Promise.all([
    fetchJSON<{ data: DropdownEntry[] }>("/parties/dropdown.json", r2).catch(() => ({ data: [] as DropdownEntry[] })),
    fetchJSON<Record<string, PartyElection[]>>("/parties/all.json", r2).catch(() => ({} as Record<string, PartyElection[]>)),
  ]);

  const allEntries = dropdownJson.data ?? [];
  const stateCodes = [MALAYSIA.key, SEMENANJUNG.key, ...STATES.map(s => s.key)];

  // Parties only; deduplicate by maps_to (multiple uid aliases can share one canonical page)
  const seen = new Set<string>();
  const entries = allEntries.filter(e => {
    if (e.type !== "party") return false;
    if (seen.has(e.maps_to)) return false;
    seen.add(e.maps_to);
    return true;
  });

  return entries
    .filter(e => !slugFilter || slugFilter.has(e.maps_to))
    .flatMap(e =>
      stateCodes.map(stateCode => ({
        params: { party: `${e.maps_to}/${stateCode}` },
        props: {
          partyUid:       e.maps_to,
          stateCode,
          partyElections: allData[`party-${e.maps_to}`] ?? [],
          dropdown:       allEntries,
        },
      }))
    );
}

const { partyUid, stateCode, partyElections, dropdown } = Astro.props as {
  partyUid:       string;
  stateCode:      string;
  partyElections: PartyElection[];
  dropdown:       DropdownEntry[];
};
---

<PartyPage partyUid={partyUid} stateCode={stateCode} partyElections={partyElections} dropdown={dropdown} />
