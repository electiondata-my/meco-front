---
import BaseLayout from "@layouts/BaseLayout.astro";
import ThemeToggle from "./ThemeToggle";
import LocaleSwitch from "./LocaleSwitch";
import { getTranslations, t } from "@i18n/index";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  needsLeaflet?: boolean;
}

const { title, description, image, needsLeaflet } = Astro.props;

const locale = Astro.currentLocale ?? "en-GB";
const i18n = await getTranslations(locale, ["common"]);
const c = (key: string) => t(i18n.common ?? {}, key);

const currentPath = Astro.url.pathname;
const homeHref = locale === "ms-MY" ? "/ms-MY" : "/";
const lp = (href: string) => locale === "ms-MY" ? "/ms-MY" + href : href;

type NavItem = { title: string; href: string; locale?: string };

const mainNavItems: NavItem[] = [
  { title: c("nav.seats"),        href: lp("/seats") },
  { title: c("nav.candidates"),   href: lp("/candidates") },
  { title: c("nav.parties"),      href: lp("/parties") },
  { title: c("nav.elections"),    href: lp("/elections") },
  { title: c("nav.byelections"),  href: lp("/byelections") },
  { title: c("nav.redelineation"), href: lp("/redelineation") },
];

const toolItems: NavItem[] = [
  { title: c("nav.query_builder"),    href: "/query-builder", locale: "en-GB" },
  { title: c("nav.catalogue"),       href: "/data-catalogue" },
  { title: c("nav.openapi"),         href: "/openapi", locale: "en-GB" },
];

function isActive(href: string) {
  return currentPath === href || (href !== "/" && currentPath.startsWith(href + "/"));
}

const footerSections = [
  {
    title: c("footer.useful_sites"),
    links: [
      { label: c("footer.spr"),        href: "https://spr.gov.my",                                     external: true },
      { label: c("footer.agc"),        href: "https://lom.agc.gov.my/subsid.php?type=pub",             external: true },
      { label: c("footer.kawasanku"), href: "https://open.dosm.gov.my/dashboard/kawasanku",            external: true },
    ],
  },
  {
    title: c("footer.about"),
    links: [
      { label: c("footer.background"),    href: lp("/about") },
      { label: c("footer.site_metrics"),  href: lp("/site-metrics") },
      { label: c("footer.documentation"), href: lp("/research") },
    ],
  },
  {
    title: c("footer.use_the_data"),
    links: [
      { label: c("footer.query_builder"), href: "/query-builder" },
      { label: c("footer.download"),      href: "/data-catalogue" },
      { label: c("footer.open_api"),      href: "/openapi" },
    ],
  },
];
---

<BaseLayout title={title} description={description} image={image} needsLeaflet={needsLeaflet}>
  <!-- ─── HEADER ─── -->
  <header
    id="navbar"
    class="sticky top-0 z-50 h-16 w-full border-b border-otl-gray-200 bg-bg-white px-4.5 shadow-button max-md:h-14 md:px-6 print:hidden"
    data-nosnippet
  >
    <div class="relative mx-auto flex h-16 max-w-screen-xl items-center justify-between gap-4 max-md:h-14">
      <!-- Logo -->
      <a href={homeHref} class="flex items-center gap-2.5 no-underline max-sm:gap-1.5">
        <img
          src="/static/logo/logo-default.png"
          alt="ElectionData.MY Logo"
          width="28"
          height="28"
          class="aspect-auto select-none object-contain"
        />
        <span class="font-poppins text-body-lg font-bold no-underline max-sm:text-body-md">
          ElectionData.MY
        </span>
      </a>

      <!-- Desktop nav + actions + mobile hamburger -->
      <div class="flex w-full flex-1 items-center justify-end lg:justify-between">
        <!-- Desktop nav items -->
        <nav class="hidden w-fit items-center lg:flex" aria-label="Main navigation">
          {mainNavItems.map(({ title, href }) => (
            <a
              href={href}
              class:list={[
                "flex flex-col items-center gap-1 px-2.5 py-1.5 text-body-sm font-medium text-txt-black-700 no-underline transition-colors rounded-md hover:text-txt-black-900",
                isActive(href) && "bg-bg-washed-active text-txt-black-900",
              ]}
            >
              {title}
            </a>
          ))}

          <!-- Tools dropdown (desktop only) -->
          <details class="relative hidden lg:block" id="tools-dropdown">
            <summary
              class="flex cursor-pointer list-none items-center gap-1 rounded-md px-2.5 py-1.5 text-body-sm font-medium text-txt-black-700 transition-colors hover:text-txt-black-900"
            >
              {c("nav.tools")}
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="absolute left-0 top-full z-50 mt-2 min-w-[13rem] rounded-xl border border-otl-gray-200 bg-bg-white p-2 shadow-button">
              <div class="flex flex-col gap-1">
                {toolItems.map(({ title, href }) => (
                  <a
                    href={href}
                    class:list={[
                      "rounded-lg px-3 py-2 text-body-sm no-underline transition-colors",
                      isActive(href)
                        ? "bg-bg-danger-50 font-medium text-txt-danger"
                        : "text-txt-black-700 hover:bg-bg-black-50 hover:text-txt-black-900",
                    ]}
                  >
                    {title}
                  </a>
                ))}
              </div>
            </div>
          </details>
        </nav>

        <!-- Actions: theme toggle + locale switch + hamburger -->
        <div class="flex items-center gap-3">
          <!-- Desktop: both visible; Mobile: both visible + hamburger -->
          <div class="hidden lg:flex gap-4">
            <ThemeToggle client:load />
            <LocaleSwitch client:load currentLocale={locale} />
          </div>
          <div class="flex items-center gap-3 lg:hidden">
            <ThemeToggle client:load />
            <LocaleSwitch client:load currentLocale={locale} />
            <button
              id="nav-open"
              aria-label="Open menu"
              aria-expanded="false"
              aria-controls="nav-mobile"
              class="box-content block h-5 w-5 text-txt-black-900"
            >
              <!-- Hamburger icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="4" y1="6"  x2="20" y2="6"  />
                <line x1="4" y1="12" x2="20" y2="12" />
                <line x1="4" y1="18" x2="20" y2="18" />
              </svg>
            </button>
            <button
              id="nav-close"
              aria-label="Close menu"
              aria-expanded="true"
              aria-controls="nav-mobile"
              class="box-content hidden h-5 w-5 text-txt-black-900"
            >
              <!-- X icon -->
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="18" y1="6"  x2="6"  y2="18" />
                <line x1="6"  y1="6"  x2="18" y2="18" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Mobile nav overlay -->
    <nav
      id="nav-mobile"
      class="fixed left-0 top-16 hidden w-full grid-cols-3 gap-0 border-b border-otl-gray-200 bg-bg-white px-3 py-6 shadow-button max-md:top-14 lg:hidden"
      aria-label="Mobile navigation"
    >
      <a href={lp("/seats")} class:list={["order-2 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/seats")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 32 33" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <g clip-path="url(#seats-clip)">
            <path d="M1.08445 18.5478C0.846584 18.2591 -0.480895 15.9854 0.185061 15.3028C0.851017 14.6201 3.49969 16.4437 3.95074 16.5633C4.4018 16.6828 4.85286 16.8622 6.21584 17.0894C7.57881 17.3166 10.369 17.8422 11.4309 21.3C11.732 22.2805 11.4446 23.4809 12.343 24.1164C12.6665 24.3452 14.9059 27.1383 14.6001 27.3612C11.9758 29.2738 2.32971 26.3665 1.93795 21.0069C1.8921 20.3797 1.47145 19.0175 1.08445 18.5478Z" fill="currentColor"/>
            <path d="M16.043 27.397C18.4575 29.3838 11.4936 28.1231 11.8795 28.6241C12.2035 29.2204 15.1542 29.8238 16.0916 29.9546C17.0888 30.0937 19.9545 29.1046 20.1099 28.7291C20.5414 27.6867 28.2255 27.9977 26.3953 26.1959C25.8443 25.6535 25.1429 24.3067 25.3886 23.909C25.5989 23.5687 24.2583 22.586 24.0502 22.0963C23.6422 21.136 32.6054 20.7098 31.3183 19.7487C30.8784 19.4202 29.7198 19.4379 29.6375 19.3739C29.0971 18.9539 32.3531 18.4341 31.8001 18.0397C30.4542 17.0798 25.513 17.685 23.0924 16.9759C22.8956 16.9182 21.8308 15.8774 21.5149 16.0874C21.3327 16.2084 19.5243 19.4135 20.261 19.9835C20.5954 20.2423 20.7843 20.5242 20.8292 20.8422C20.8741 21.1603 19.4764 21.8546 19.0569 21.9238C17.3823 22.2002 19.488 24.1826 18.5336 24.847C17.6418 25.4679 14.5004 26.1277 16.043 27.397Z" fill="currentColor"/>
            <path d="M21.2421 7.55641C21.2421 11.2119 15.5304 16.3241 15.5304 16.3241C15.5304 16.3241 9.81873 11.2119 9.81873 7.55641C9.81873 4.35787 12.5021 1.84473 15.5304 1.84473C18.5587 1.84473 21.2421 4.35787 21.2421 7.55641Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <ellipse cx="15.5304" cy="7.54564" rx="1.76146" ry="1.76146" fill="currentColor"/>
          </g>
          <defs><clipPath id="seats-clip"><rect width="32" height="32" fill="white" transform="translate(0 0.324097)"/></clipPath></defs>
        </svg>
        {c("nav.seats")}
      </a>

      <a href={lp("/candidates")} class:list={["order-1 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/candidates")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
        </svg>
        {c("nav.candidates")}
      </a>

      <a href={lp("/parties")} class:list={["order-3 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/parties")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0 2.77-.693a9 9 0 0 1 6.208.682l.108.054a9 9 0 0 0 6.086.71l3.114-.732a48.524 48.524 0 0 1-.005-10.499l-3.11.732a9 9 0 0 1-6.085-.711l-.108-.054a9 9 0 0 0-6.208-.682L3 4.5M3 15V4.5" />
        </svg>
        {c("nav.parties")}
      </a>

      <a href={lp("/elections")} class:list={["order-5 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/elections")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75" />
        </svg>
        {c("nav.elections")}
      </a>

      <a href={lp("/byelections")} class:list={["order-4 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/byelections")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
        </svg>
        {c("nav.byelections")}
      </a>

      <a href={lp("/redelineation")} class:list={["order-6 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive(lp("/redelineation")) ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 32 33" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M10.4 5.76404L3.20001 8.96404V28.964L10.4 25.764M10.4 5.76404V25.764M10.4 5.76404L14.8 7.36404L15.9 7.76404M10.4 25.764L19.2 28.964M19.2 28.964L26.4 25.764V15.764V13.924M19.2 28.964V17.924" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M25.6647 9.62074L24.9775 10.3135L23.6032 11.699L20.8545 14.4701L17.1152 14.8198L17.5524 11.1411L20.3011 8.37009L21.6754 6.98457L22.3626 6.2918M25.6647 9.62074L26.3519 8.92797L28.0872 7.1785C28.3912 6.87208 28.3912 6.37528 28.0872 6.06885L25.8858 3.84957C25.5819 3.54314 25.0891 3.54314 24.7851 3.84957L23.0498 5.59904L22.3626 6.2918M25.6647 9.62074L22.3626 6.2918" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {c("nav.redelineation")}
      </a>

      <a href="/query-builder" class:list={["order-7 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive("/query-builder") ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
        </svg>
        {c("nav.query_builder")}
      </a>

      <a href="/data-catalogue" class:list={["order-8 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive("/data-catalogue") ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        {c("nav.catalogue")}
      </a>

      <a href="/openapi" class:list={["order-9 flex flex-col items-center gap-1 px-2 py-2 text-body-sm font-medium text-center no-underline transition-colors", isActive("/openapi") ? "text-txt-danger" : "text-txt-black-500"]}>
        <svg class="size-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 5.625c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
        </svg>
        {c("nav.openapi")}
      </a>
    </nav>
  </header>

  <!-- ─── PAGE CONTENT ─── -->
  <main class="flex flex-1 flex-col">
    <slot />
  </main>

  <!-- ─── FOOTER ─── -->
  <footer class="w-full border-t border-otl-gray-200 bg-bg-white px-4 pb-14 pt-10 md:px-6 md:pb-16 md:pt-12">
    <div class="mx-auto grid max-w-screen-xl gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(520px,640px)] lg:gap-12">
      <div class="flex max-w-[420px] items-start gap-4">
        <a
          href={homeHref}
          class="flex size-10 shrink-0 items-center justify-center rounded-lg border border-otl-gray-200 bg-bg-white shadow-button transition-opacity hover:opacity-80 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-fr-danger"
        >
          <img
            src="/static/logo/logo-default.png"
            alt="ElectionData.MY Logo"
            width="28"
            height="28"
            loading="lazy"
            class="aspect-auto select-none object-contain"
          />
        </a>
        <div class="flex min-w-0 flex-col gap-1">
          <a
            href={homeHref}
            class="w-fit font-poppins text-body-lg font-bold text-txt-black-900 no-underline transition-opacity hover:opacity-80"
          >
            ElectionData.MY
          </a>
          <p class="text-body-sm leading-6 text-txt-black-500">
            {c("footer.copyright")}
          </p>
        </div>
      </div>

      <div class="grid w-full max-w-[640px] grid-cols-2 gap-x-8 gap-y-9 sm:w-fit sm:grid-cols-[repeat(3,max-content)] sm:gap-x-16 lg:gap-x-20 lg:justify-self-end">
        {footerSections.map(section => (
          <div class="flex min-w-0 flex-col gap-3">
            <p class="text-body-sm font-semibold text-txt-black-900">{section.title}</p>
            <nav aria-label={section.title} class="flex flex-col items-start gap-1">
              {section.links.map(link => (
                link.href === "#"
                  ? <span class="inline-flex w-fit cursor-default text-body-sm leading-6 text-txt-black-400 no-underline opacity-60">{link.label}</span>
                  : <a
                      href={link.href}
                      target={link.external ? "_blank" : undefined}
                      rel={link.external ? "noopener noreferrer" : undefined}
                      class="inline-flex w-fit text-body-sm leading-6 text-txt-black-500 transition-colors hover:text-txt-danger focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-fr-danger no-underline"
                    >
                      {link.label}
                    </a>
              ))}
            </nav>
          </div>
        ))}
      </div>
    </div>
  </footer>
</BaseLayout>

<!-- Mobile hamburger toggle (vanilla JS) -->
<script>
  const open = document.getElementById("nav-open");
  const close = document.getElementById("nav-close");
  const menu = document.getElementById("nav-mobile");

  function openMenu() {
    menu?.classList.remove("hidden");
    menu?.classList.add("grid");
    open?.classList.add("hidden");
    close?.classList.remove("hidden");
  }

  function closeMenu() {
    menu?.classList.add("hidden");
    menu?.classList.remove("grid");
    close?.classList.add("hidden");
    open?.classList.remove("hidden");
  }

  open?.addEventListener("click", (event) => {
    event.stopPropagation();
    openMenu();
  });
  close?.addEventListener("click", (event) => {
    event.stopPropagation();
    closeMenu();
  });

  document.addEventListener("click", (event) => {
    if (!menu || menu.classList.contains("hidden")) return;
    const target = event.target as Node;
    if (menu.contains(target) || open?.contains(target) || close?.contains(target)) return;
    closeMenu();
  });

  // Close on any nav link click within the mobile menu
  menu?.querySelectorAll("a").forEach(a => a.addEventListener("click", closeMenu));
</script>

<!-- Close <details> dropdown on outside click -->
<script>
  document.addEventListener("click", (e) => {
    const dropdown = document.getElementById("tools-dropdown") as HTMLDetailsElement | null;
    if (dropdown && !dropdown.contains(e.target as Node)) {
      dropdown.removeAttribute("open");
    }
  });
</script>
