---
import Layout from "@src/components/Layout/index.astro";
import SeatsMapbox from "./SeatsMapbox";
import SeatElectionTable from "./SeatElectionTable";
import { getTranslations, t } from "@i18n/index";

type MapPlot = {
  zoom: number;
  center: [number, number];
  polygons: Record<string, [string, string[]]>;
};

type LineageRow = Record<string, any>;

type ElectionRow = {
  election_name: string;
  seat: string;
  state: string;
  date: string;
  party: string;
  party_uid: string;
  coalition: string;
  name: string;
  majority: number;
  majority_perc: number;
  voter_turnout: number;
  voter_turnout_perc: number;
};

type RedelineationRow = { date: string; change_en: string; change_ms: string };
type ResultRow = ElectionRow | RedelineationRow;

interface Props {
  type: string;
  slug: string;
  seatName: string; // e.g. "P.096 Kuala Selangor, Selangor"
  seatData: {
    map_plot: MapPlot;
    map_lineage: LineageRow[];
    results: ResultRow[];
  };
}

const { type, slug, seatName, seatData } = Astro.props;
const locale = Astro.currentLocale ?? "en-GB";
const isMalay = locale.startsWith("ms");
const localePrefix = isMalay ? "/ms-MY" : "";

const i18n = await getTranslations(locale, ["common", "seats"]);
const c = (key: string) => t(i18n.common ?? {}, key);
const s = (key: string) => t(i18n.seats ?? {}, key);

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";
const mapboxAccount = import.meta.env.PUBLIC_MAPBOX_ACCOUNT ?? "";
const apiBase = import.meta.env.PUBLIC_API_URL_R2 ?? "";
const r2Url = apiBase;

// Parse seat display name and state from "P.096 Kuala Selangor, Selangor"
const commaIdx = seatName.lastIndexOf(", ");
const seatDisplay = commaIdx >= 0 ? seatName.slice(0, commaIdx) : seatName;
const stateDisplay = commaIdx >= 0 ? seatName.slice(commaIdx + 2) : "";

// Most recent election result (first non-redelineation row)
const mostRecent = seatData.results.find(
  (r): r is ElectionRow => !("change_en" in r),
);

const seatTypeParlimen = type === "parlimen";
const seatTypeLabel = seatTypeParlimen
  ? isMalay ? "Parlimen" : "Parliament"
  : "DUN";

const pageTitle = `${seatDisplay}${stateDisplay ? `, ${stateDisplay}` : ""} | ElectionData.MY`;
const pageDescription = s("hero.description");
const ogImage = `${apiBase}/og-image/${slug}.png`;

const lineageType = type as "parlimen" | "dun";
---

<Layout title={pageTitle} description={pageDescription} ogImage={ogImage}>
  <!-- Hero -->
  <section class="w-full bg-gradient-radial from-bg-danger-100 to-bg-white">
    <div class="mx-auto flex max-w-[727px] flex-col items-center space-y-4 px-4 pb-8 pt-16 text-center md:px-6 lg:space-y-6">
      <p class="text-center text-body-xs font-semibold uppercase tracking-[0.1em] text-txt-danger lg:text-body-lg">
        {s("hero.category") || "Electoral Constituencies"}
      </p>
      <h1 class="text-center font-heading text-heading-sm font-semibold text-txt-black-900 lg:text-heading-md">
        {s("hero.header") || "Electoral Constituencies"}
      </h1>
      {s("hero.description") !== "hero.description" && (
        <p class="w-full text-center text-body-sm text-txt-black-700 lg:text-body-md">
          {s("hero.description")}
        </p>
      )}
    </div>
  </section>

  <!-- Sticky search bar -->
  <div id="seat-search-bar" class="sticky top-16 z-20 w-full border border-transparent px-4.5 py-3 transition-all duration-300 md:px-0">
    <div class="mx-auto w-full max-w-[727px]">
      <div class="combobox relative" data-type="seat">
        <div class="flex items-center overflow-hidden rounded-full border border-otl-gray-200 bg-bg-white shadow-button focus-within:border-otl-danger-300 focus-within:ring focus-within:ring-otl-danger-200">
          <input
            type="text"
            class="combobox-input w-full border-0 bg-transparent py-2.5 pl-5 pr-2 text-body-md text-txt-black-700 placeholder:text-txt-black-500 focus:outline-none"
            placeholder={s("search_seat") || "Search for a seat…"}
            autocomplete="off"
            spellcheck="false"
            value={`${seatDisplay}${stateDisplay ? `, ${stateDisplay}` : ""} (${seatTypeLabel})`}
          />
          <button
            type="button"
            class="combobox-clear mr-1 hidden h-7 w-7 shrink-0 items-center justify-center rounded-full text-txt-black-400 hover:text-txt-black-700"
            aria-label="Clear"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
            </svg>
          </button>
          <button
            type="button"
            class="combobox-btn mr-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-bg-danger-500 to-bg-danger-700 text-txt-white shadow-sm"
            aria-label={s("search_seat") || "Search"}
          >
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
        <ul class="combobox-list absolute left-0 right-0 top-full z-50 mt-1.5 hidden max-h-60 overflow-y-auto rounded-xl border border-otl-gray-200 bg-bg-white py-1 shadow-lg"></ul>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-screen-xl space-y-10 px-4.5 pb-16 pt-6 md:px-6 lg:space-y-16">

    <!-- Seat header (static, crawlable) -->
    <div class="mx-auto max-w-[727px] space-y-3 text-center">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span class="rounded-full border border-otl-danger-200 bg-bg-danger-50 px-2.5 py-0.5 text-body-xs font-medium text-txt-danger">
          {seatTypeLabel}
        </span>
        {stateDisplay && (
          <span class="rounded-full border border-otl-gray-200 bg-bg-washed px-2.5 py-0.5 text-body-xs font-medium text-txt-black-500">
            {stateDisplay}
          </span>
        )}
      </div>
      <h2 class="font-heading text-heading-xs font-semibold text-txt-black-900 lg:text-heading-2xs">
        {seatDisplay}
      </h2>
      {mostRecent && (
        <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-body-sm text-txt-black-700">
          <span class="font-medium">{mostRecent.name}</span>
          <span class="text-txt-black-300" aria-hidden="true">·</span>
          <div class="flex items-center gap-1.5">
            <img
              src={`/static/images/parties/${mostRecent.party_uid}.png`}
              alt={mostRecent.party}
              width={28}
              height={16}
              class="border border-otl-gray-200"
              onerror="this.style.display='none'"
            />
            <span>{mostRecent.party}</span>
          </div>
          {mostRecent.coalition && mostRecent.coalition !== "ALONE" && (
            <>
              <span class="text-txt-black-300" aria-hidden="true">·</span>
              <span class="text-txt-black-500">{mostRecent.coalition}</span>
            </>
          )}
        </div>
      )}
    </div>

    <!-- Section 2: Mapbox map -->
    <section class="space-y-3">
      <div class="relative h-[400px] w-full overflow-hidden rounded-lg border border-otl-gray-200 lg:h-[400px]">
        <SeatsMapbox
          client:only="react"
          mapPlot={seatData.map_plot}
          seatType={type as "parlimen" | "dun"}
          mapboxToken={mapboxToken}
          mapboxAccount={mapboxAccount}
          mapboxLabel={s("boundaries_years") || "Delimitation Years"}
          lineageTitle={s("lineage.title") || "Geo-History"}
          lineageYearLabel={s("lineage.year") || "Year"}
          lineageParlimenLabel={s("lineage.parlimen") || "Parliament"}
          lineageDunLabel={s("lineage.dun") || "DUN"}
          lineageNDunsLabel={s("lineage.n_duns") || "No. of DUNs"}
          lineageDunsLabel={s("lineage.duns") || "DUNs"}
          lineage={seatData.map_lineage}
          closeLabel={c("close") || "Close"}
        />
      </div>
      <p class="text-center text-sm italic text-txt-black-500" set:html={
        s("attribution_boundary_data") !== "attribution_boundary_data"
          ? s("attribution_boundary_data").replace(/\[([^\]]+)\]\(([^)]+)\)/, '<a href="$2" class="underline hover:opacity-70" target="_blank" rel="noopener noreferrer">$1</a>')
          : "Boundary data: Tindak Malaysia"
      } />
    </section>

    <!-- Section 3: Election history table -->
    <section class="space-y-4">
      <h2 class="text-center font-heading text-heading-2xs font-semibold">
        {s("title") || "Complete election history of "}
        <span class="text-txt-danger">{seatDisplay}</span>
      </h2>
      <SeatElectionTable
        client:load
        results={seatData.results}
        seatLabel={seatDisplay}
        apiBase={apiBase}
        isMalay={isMalay}
        translations={{ common: i18n.common ?? {}, seats: i18n.seats ?? {} }}
      />
    </section>
  </div>
</Layout>

<script define:vars={{ localePrefix, r2Url, seatType: type, isMalay }}>
  function esc(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  var _options = null;
  var _optionsPromise = null;
  var SESSION_KEY = "seatOptions";

  var parlLabel = isMalay ? "Parlimen" : "Parliament";
  var dunLabel = "DUN";

  function loadOptions() {
    if (!_optionsPromise) {
      try {
        var cached = sessionStorage.getItem(SESSION_KEY);
        if (cached) {
          _options = JSON.parse(cached);
          _optionsPromise = Promise.resolve(_options);
          return _optionsPromise;
        }
      } catch {}
      _optionsPromise = fetch(r2Url + "/seats/current/dropdown.json")
        .then(function(r) { return r.json(); })
        .then(function(json) {
          var raw = json.data ?? [];
          _options = raw.map(function(s) {
            var commaIdx = s.seat.lastIndexOf(", ");
            var seatPart = commaIdx >= 0 ? s.seat.slice(0, commaIdx) : s.seat;
            var statePart = commaIdx >= 0 ? s.seat.slice(commaIdx + 2) : "";
            var typeLabel = s.type === "parlimen" ? parlLabel : dunLabel;
            return {
              value: s.type + "/" + s.slug,
              label: seatPart + (statePart ? ", " + statePart : "") + " (" + typeLabel + ")",
              searchLabel: seatPart + " " + statePart + " " + s.type,
            };
          });
          try { sessionStorage.setItem(SESSION_KEY, JSON.stringify(_options)); } catch {}
          return _options;
        });
    }
    return _optionsPromise;
  }

  function tokenize(str) {
    return str.toLowerCase().replace(/[.,]/g, "").split(/\s+/).filter(Boolean);
  }

  function score(opt, tokens) {
    var label = opt.searchLabel.toLowerCase();
    var matches = 0;
    for (var i = 0; i < tokens.length; i++) {
      if (label.includes(tokens[i])) matches++;
    }
    return matches;
  }

  function initCombobox(wrapper) {
    var input = wrapper.querySelector(".combobox-input");
    var btn = wrapper.querySelector(".combobox-btn");
    var clearBtn = wrapper.querySelector(".combobox-clear");
    var list = wrapper.querySelector(".combobox-list");
    var selected = "";
    var activeIdx = -1;

    function showList(items) {
      if (!items.length) { list.classList.add("hidden"); return; }
      list.innerHTML = items.slice(0, 50).map(function(item, i) {
        return '<li role="option" data-value="' + esc(item.value) + '" class="cursor-pointer px-4 py-2.5 text-body-sm hover:bg-bg-washed" tabindex="-1">' + esc(item.label) + '</li>';
      }).join("");
      list.classList.remove("hidden");
      activeIdx = -1;
    }

    function hideList() {
      list.classList.add("hidden");
      activeIdx = -1;
    }

    function filterAndShow(q) {
      if (!_options) return;
      var tokens = tokenize(q);
      if (!tokens.length) { showList(_options.slice(0, 50)); return; }
      var scored = _options
        .map(function(opt) { return { opt: opt, score: score(opt, tokens) }; })
        .filter(function(x) { return x.score > 0; })
        .sort(function(a, b) { return b.score - a.score; });
      showList(scored.map(function(x) { return x.opt; }));
    }

    function navigate(target) {
      window.location.href = localePrefix + "/seats/" + target;
    }

    input.addEventListener("focus", function() {
      loadOptions().then(function() {
        filterAndShow(input.value);
      });
    });

    input.addEventListener("input", function() {
      if (clearBtn) clearBtn.classList.toggle("hidden", !input.value);
      filterAndShow(input.value);
    });

    if (clearBtn) {
      clearBtn.addEventListener("click", function() {
        input.value = "";
        clearBtn.classList.add("hidden");
        if (_options) filterAndShow("");
        input.focus();
      });
    }

    btn.addEventListener("click", function() {
      if (selected) {
        navigate(selected);
      } else {
        loadOptions().then(function() { filterAndShow(input.value); input.focus(); });
      }
    });

    list.addEventListener("mousedown", function(e) {
      var li = e.target.closest("li[data-value]");
      if (!li) return;
      e.preventDefault();
      var val = li.dataset.value;
      selected = val;
      var opt = (_options || []).find(function(o) { return o.value === val; });
      if (opt) input.value = opt.label;
      hideList();
      navigate(val);
    });

    input.addEventListener("keydown", function(e) {
      var items = list.querySelectorAll("li[data-value]");
      if (e.key === "ArrowDown") {
        e.preventDefault();
        activeIdx = Math.min(activeIdx + 1, items.length - 1);
        items.forEach(function(el, i) { el.classList.toggle("bg-bg-washed", i === activeIdx); });
        if (items[activeIdx]) items[activeIdx].scrollIntoView({ block: "nearest" });
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        activeIdx = Math.max(activeIdx - 1, -1);
        items.forEach(function(el, i) { el.classList.toggle("bg-bg-washed", i === activeIdx); });
        if (items[activeIdx]) items[activeIdx].scrollIntoView({ block: "nearest" });
      } else if (e.key === "Enter") {
        e.preventDefault();
        if (activeIdx >= 0 && items[activeIdx]) {
          items[activeIdx].dispatchEvent(new MouseEvent("mousedown", { bubbles: true }));
        }
      } else if (e.key === "Escape") {
        hideList();
      }
    });

    document.addEventListener("click", function(e) {
      if (!wrapper.contains(e.target)) hideList();
    });
  }

  document.querySelectorAll(".combobox[data-type='seat']").forEach(initCombobox);
</script>
