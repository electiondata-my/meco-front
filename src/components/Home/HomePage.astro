</Layout>

<style>
  /* Theme-aware map thumbnails */
  .img-dark { display: none; }
  :global(.dark) .img-dark { display: block; }
  :global(.dark) .img-light { display: none; }
</style>

<script>
  // ── Tabs ──────────────────────────────────────────────────────────────────
  const tabBtns  = document.querySelectorAll<HTMLButtonElement>(".tab-btn");
  const tabPanels = document.querySelectorAll<HTMLElement>(".tab-panel");

  const ACTIVE_CLASSES   = ["rounded-md", "border", "border-otl-gray-200", "bg-bg-dialog-active", "text-txt-black-900", "shadow-button"];
  const INACTIVE_CLASSES = ["text-txt-black-500"];

  function activateTab(index: number) {
    tabBtns.forEach((btn, i) => {
      if (i === index) {
        btn.classList.add(...ACTIVE_CLASSES);
        btn.classList.remove(...INACTIVE_CLASSES);
      } else {
        btn.classList.remove(...ACTIVE_CLASSES);
        btn.classList.add(...INACTIVE_CLASSES);
      }
    });
    tabPanels.forEach((panel, i) => panel.classList.toggle("hidden", i !== index));
  }

  tabBtns.forEach(btn => btn.addEventListener("click", () => activateTab(Number(btn.dataset.index))));

  // ── Combobox ──────────────────────────────────────────────────────────────
  function esc(s: string) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  function initCombobox(wrapper: HTMLElement) {
    const type     = wrapper.dataset.type!;
    const selectId = wrapper.dataset.select!;
    const selectEl = document.getElementById(selectId) as HTMLSelectElement | null;
    if (!selectEl) return;

    const allOptions = Array.from(selectEl.options)
      .filter(o => o.value)
      .map(o => ({ value: o.value, label: o.text.trim(), partyType: o.dataset.partyType }));

    const input = wrapper.querySelector<HTMLInputElement>(".combobox-input")!;
    const btn   = wrapper.querySelector<HTMLButtonElement>(".combobox-btn")!;
    const list  = wrapper.querySelector<HTMLUListElement>(".combobox-list")!;
    let selected = "";
    let activeIdx = -1;

    function href(val: string) {
      if (type === "party")     return `/parties/${val}/mys`;
      if (type === "candidate") return `/candidates/${val}`;
      if (type === "election")  return `/elections/${val}`;
      return `/seats/${val}`;
    }

    list.addEventListener("mousedown", (e: MouseEvent) => {
      const li = (e.target as Element).closest<HTMLLIElement>("li[data-value]");
      if (!li) return;
      e.preventDefault();
      selected = li.dataset.value!;
      input.value = allOptions.find(o => o.value === selected)?.label ?? "";
      list.classList.add("hidden");
      window.location.href = href(selected);
    });

    function render(options: typeof allOptions) {
      activeIdx = -1;
      const items = options.slice(0, 150);
      if (options.length === 0) {
        list.innerHTML = `<li class="px-4 py-2 text-sm italic text-txt-black-500">No results</li>`;
        return;
      }

      if (type === "party") {
        list.innerHTML = items.map(o => {
          const folder = o.partyType === "coalition" ? "coalitions" : "parties";
          const pillCls = o.partyType === "coalition"
            ? "border-blue-400 bg-blue-50/60 text-blue-600"
            : "border-red-400 bg-red-50/60 text-red-600";
          const pillText = o.partyType === "coalition" ? "Coalition" : "Party";
          const fallback = `this.replaceWith(Object.assign(document.createElement('div'),{className:'flex h-[18px] w-[28px] items-center justify-center rounded-sm border border-otl-gray-200 bg-bg-black-50 text-xs text-txt-black-400',textContent:'?'}))`;
          return `<li class="flex cursor-pointer select-none items-center gap-2 px-3 py-2 text-sm text-txt-black-700 hover:bg-bg-black-50" data-value="${esc(o.value)}">
            <div class="flex h-[18px] w-7 shrink-0 items-center justify-center">
              <img src="/static/images/${folder}/${esc(o.value)}.png" alt="" class="max-h-[18px] max-w-[28px] border border-otl-gray-200 object-contain" onerror="${fallback}" />
            </div>
            <span class="grow truncate">${esc(o.label)}</span>
            <span class="ml-auto shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium ${pillCls}">${pillText}</span>
          </li>`;
        }).join("");
      } else if (type === "election") {
        list.innerHTML = items.map(o => {
          const stateKey = o.value.split("/")[0];
          return `<li class="flex cursor-pointer select-none items-center gap-2 px-3 py-2 text-sm text-txt-black-700 hover:bg-bg-black-50" data-value="${esc(o.value)}">
            <img src="/static/images/states/${stateKey}.jpeg" alt="" class="h-4 w-auto shrink-0 border border-otl-gray-200" onerror="this.style.display='none'" />
            <span class="grow truncate">${esc(o.label)}</span>
          </li>`;
        }).join("");
      } else {
        list.innerHTML = items.map(o =>
          `<li class="cursor-pointer truncate px-4 py-2 text-sm text-txt-black-700 hover:bg-bg-black-50" data-value="${esc(o.value)}">${esc(o.label)}</li>`
        ).join("");
      }
    }

    function highlight(idx: number) {
      const items = [...list.querySelectorAll<HTMLLIElement>("li[data-value]")];
      items.forEach((li, i) => {
        if (i === idx) li.classList.add("bg-bg-black-50");
        else li.classList.remove("bg-bg-black-50");
      });
      activeIdx = idx;
      if (idx >= 0) items[idx]?.scrollIntoView({ block: "nearest" });
    }

    function open() {
      const q = input.value.toLowerCase().trim();
      if (!q) {
        render(allOptions);
        list.classList.remove("hidden");
        return;
      }
      const tokens = q.split(/\s+/);
      render(allOptions.filter(o => tokens.every(tok => o.label.toLowerCase().includes(tok))));
      list.classList.remove("hidden");
    }

    function close() { list.classList.add("hidden"); activeIdx = -1; }

    let _debounceTimer: ReturnType<typeof setTimeout>;
    input.addEventListener("input",  () => { selected = ""; clearTimeout(_debounceTimer); _debounceTimer = setTimeout(open, 200); });
    input.addEventListener("focus",  open);
    input.addEventListener("blur",   () => setTimeout(close, 150));
    input.addEventListener("keydown", (e: KeyboardEvent) => {
      const items = [...list.querySelectorAll<HTMLLIElement>("li[data-value]")];
      const isOpen = !list.classList.contains("hidden");
      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (!isOpen) { open(); return; }
        highlight(Math.min(activeIdx + 1, items.length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (!isOpen) return;
        highlight(Math.max(activeIdx - 1, 0));
      } else if (e.key === "Enter") {
        if (isOpen && activeIdx >= 0 && items[activeIdx]) {
          e.preventDefault();
          selected = items[activeIdx].dataset.value!;
          input.value = allOptions.find(o => o.value === selected)?.label ?? "";
          close();
          window.location.href = href(selected);
        }
      } else if (e.key === "Escape") {
        close();
      }
    });
    btn.addEventListener("click",    () => { if (selected) window.location.href = href(selected); else input.focus(); });
    document.addEventListener("click", e => { if (!wrapper.contains(e.target as Node)) close(); });
  }

  document.querySelectorAll<HTMLElement>(".combobox").forEach(initCombobox);

  // ── Cmd/Ctrl+K shortcut ───────────────────────────────────────────────────
  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "k" && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      const activePanel = [...tabPanels].find(p => !p.classList.contains("hidden"));
      const input = activePanel?.querySelector<HTMLInputElement>(".combobox-input");
      if (input) { input.value = ""; input.focus(); }
    }
  });

  // ── View count ────────────────────────────────────────────────────────────
  const vcEl = document.getElementById("hero-view-count") as HTMLElement | null;
  if (vcEl) {
    const { token, host } = vcEl.dataset as { token?: string; host?: string };
    if (token && host) {
      fetch(`${host}/v0/pipes/views_by_page.json?token=${token}&page_id=sitewide`)
        .then(r => r.json())
        .then(data => {
          const views = data?.data?.[0]?.hits;
          if (views != null) vcEl.textContent = `${Number(views).toLocaleString()} views`;
        })
        .catch(() => {});
    }
  }
</script>
