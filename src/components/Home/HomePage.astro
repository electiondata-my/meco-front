        </div>
        <div class="flex flex-1 flex-col gap-4 rounded-lg border border-otl-gray-200 bg-gradient-to-r from-bg-dialog to-bg-gray-50 p-5 lg:gap-6 lg:p-[30px]">
          <div class="flex size-10 shrink-0 items-center justify-center rounded-lg border border-otl-gray-200 shadow-button lg:size-[52px]">
            <svg class="size-5 text-txt-black-700 lg:size-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.589-1.202L18.75 4.97Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.589-1.202L5.25 5.49Z" /></svg>
          </div>
          <div class="flex flex-col gap-2">
            <h3 class="text-body-lg font-semibold">{h("trust.neutral.title")}</h3>
            <p class="text-sm leading-5 text-txt-black-500">{h("trust.neutral.description")}</p>
          </div>
          <a href="/about" class="flex items-center gap-1 text-sm font-medium text-txt-danger no-underline hover:underline">
            {h("trust.neutral.link") || "Learn more"}
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M8.22 5.22a.75.75 0 0 1 1.06 0l4.25 4.25a.75.75 0 0 1 0 1.06l-4.25 4.25a.75.75 0 0 1-1.06-1.06L11.94 10 8.22 6.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" /></svg>
