---
import Layout from "@src/components/Layout/index.astro";
import { getTranslations, t } from "@i18n/index";
import CandidateElectionTable from "./CandidateElectionTable";

type CandidateElection = {
  type: "parlimen" | "dun";
  election_name: string;
  date: string;
  seat: string;
  party: string;
  party_uid?: string;
  votes: number;
  votes_perc: number;
  result: string;
};

interface Props {
  slug: string;
  candidateOptions?: { label: string; value: string }[] | null;
  currentOption: { name: string; slug: string; w: string; l: string } | undefined;
  candData: CandidateElection[] | null;
  isRoot?: boolean;
}

const { slug, candidateOptions, currentOption, candData, isRoot = false } = Astro.props;
const locale = Astro.currentLocale ?? "en-GB";
const isMalay = locale.startsWith("ms");

if (!candData) return Astro.redirect(isMalay ? "/ms-MY/candidates" : "/candidates");

const i18n = await getTranslations(locale, ["common", "candidates"]);

const parlimen = candData.filter(e => e.type === "parlimen");
const dun      = candData.filter(e => e.type === "dun");

const cd = (key: string) => t(i18n.candidates ?? {}, key);


const localePrefix = isMalay ? "/ms-MY" : "";
const pageTitle = `${isRoot ? "Candidates" : currentOption?.name ?? "Candidates"} | ElectionData.MY`;

const tbToken = import.meta.env.PUBLIC_TINYBIRD_TOKEN;
const tbHost  = import.meta.env.PUBLIC_API_URL_TB;
const r2Url   = import.meta.env.PUBLIC_API_URL_R2;
---

<Layout title={pageTitle}>
  <!-- Hero -->
  <section class="w-full bg-gradient-radial from-bg-danger-100 to-bg-white">
    <div class="mx-auto flex max-w-[727px] flex-col items-center space-y-4 px-4 pb-8 pt-16 text-center md:px-6 lg:space-y-6">
      <p class="text-center text-body-xs font-semibold uppercase tracking-[0.1em] text-txt-danger lg:text-body-lg">
        {cd("hero.category") || "Candidates"}
      </p>
      <h1 class="text-center font-heading text-heading-sm font-semibold text-txt-black-900 lg:text-heading-md">
        {cd("hero.header") || "Candidates Explorer"}
      </h1>
      {cd("hero.description") !== "hero.description" && (
        <p class="w-full text-center text-body-sm text-txt-black-700 lg:text-body-md">{cd("hero.description")}</p>
      )}
      <p class="flex items-center justify-center gap-0.5 text-body-sm text-txt-black-500">
        <svg class="size-4.5 self-center" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
          <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.186A10.004 10.004 0 0 1 10 3c4.257 0 7.893 2.66 9.336 6.41.147.381.146.804 0 1.186A10.004 10.004 0 0 1 10 17c-4.257 0-7.893-2.66-9.336-6.41ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
        </svg>
        <span id="cand-view-count" data-token={tbToken} data-host={tbHost}>---</span>
      </p>
    </div>
  </section>

  <!-- Main content -->
  <div class="px-4.5 pb-6 pt-4 md:px-6 lg:pb-16">
  <div class="mx-auto w-full max-w-screen-xl space-y-8 lg:space-y-16">

    <!-- Candidate search -->
    <div class="mx-auto mt-3 w-full md:w-[679px]">
      <div class="combobox relative" data-type="candidate">
        <div class="flex items-center overflow-hidden rounded-full border border-otl-gray-200 bg-bg-white shadow-button focus-within:border-otl-danger-300 focus-within:ring focus-within:ring-otl-danger-200">
          <input
            type="text"
            class="combobox-input w-full border-0 bg-transparent py-2.5 pl-5 pr-2 text-body-md text-txt-black-700 placeholder:text-txt-black-500 focus:outline-none"
            placeholder={cd("search_candidate") || "Search candidate…"}
            autocomplete="off"
            spellcheck="false"
            value={currentOption ? `${currentOption.name} (W${currentOption.w}, L${currentOption.l})` : ""}
          />
          <button
            type="button"
            class={`combobox-clear mr-1 h-5 w-5 shrink-0 items-center justify-center rounded-full text-txt-black-500 hover:text-txt-black-700 ${currentOption ? "flex" : "hidden"}`}
            aria-label="Clear"
          >
            <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
              <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22Z" />
            </svg>
          </button>
          <button
            type="button"
            class="combobox-btn mr-2 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-gradient-to-b from-danger-400 to-danger-600 text-white"
            aria-label="Search"
          >
            <svg class="size-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11ZM2 9a7 7 0 1 1 12.452 4.391l3.328 3.329a.75.75 0 1 1-1.06 1.06l-3.329-3.328A7 7 0 0 1 2 9Z" clip-rule="evenodd" />
            </svg>
          </button>
        </div>
        <ul class="combobox-list absolute left-0 right-0 top-full z-50 mt-1.5 hidden max-h-60 overflow-y-auto rounded-xl border border-otl-gray-200 bg-bg-white py-1 shadow-lg"></ul>
      </div>
    </div>

    <!-- Election history (React island — handles tabs, vote bars, full results modal) -->
    <div class="mt-6 lg:mt-10">
      <CandidateElectionTable
        client:load
        parlimen={parlimen}
        dun={dun}
        candidateName={currentOption?.name ?? slug}
        candidateStats={currentOption ? `W${currentOption.w}, L${currentOption.l}` : undefined}
        apiBase={import.meta.env.PUBLIC_API_URL_S3}
        isMalay={isMalay}
        translations={{ common: i18n.common ?? {}, candidates: i18n.candidates ?? {} }}
      />
    </div>
  </div>
  </div>
</Layout>

<script define:vars={{ localePrefix, r2Url, preloadedOptions: candidateOptions ?? null }}>
  function esc(s) {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  // preloadedOptions is set on the index page (build-time data); null on slug pages
  var _options = preloadedOptions;
  var _optionsPromise = preloadedOptions ? Promise.resolve(preloadedOptions) : null;

  var SESSION_KEY = "candidateOptions";

  function loadOptions() {
    if (!_optionsPromise) {
      try {
        var cached = sessionStorage.getItem(SESSION_KEY);
        if (cached) {
          _options = JSON.parse(cached);
          _optionsPromise = Promise.resolve(_options);
          return _optionsPromise;
        }
      } catch {}
      _optionsPromise = fetch(r2Url + "/candidates/dropdown.json")
        .then(function(r) { return r.json(); })
        .then(function(json) {
          var raw = json.data ?? [];
          _options = raw.slice()
            .sort(function(a, b) {
              var ca = Number(a.c), cb = Number(b.c);
              if (ca !== cb) return cb - ca;
              return Number(b.w) - Number(a.w);
            })
            .map(function(c) {
              return { value: c.slug, label: c.name + " (W" + c.w + ", L" + c.l + ")" };
            });
          try { sessionStorage.setItem(SESSION_KEY, JSON.stringify(_options)); } catch {}
          return _options;
        });
    }
    return _optionsPromise;
  }

  function initCombobox(wrapper) {
    const input     = wrapper.querySelector(".combobox-input");
    const btn       = wrapper.querySelector(".combobox-btn");
    const clearBtn  = wrapper.querySelector(".combobox-clear");
    const list      = wrapper.querySelector(".combobox-list");
    let selected = "";
    let activeIdx = -1;

    function focusInputWithoutScroll() {
      const y = window.scrollY;
      input.focus({ preventScroll: true });
      window.scrollTo({ top: y, left: window.scrollX });
    }

    function goToCandidate(value) {
      try {
        sessionStorage.setItem("candidateSearchScrollY", String(window.scrollY));
      } catch {}
      window.location.href = `${localePrefix}/candidates/${value}`;
    }

    function updateClear() {
      if (!clearBtn) return;
      if (input.value.length > 0) {
        clearBtn.classList.remove("hidden");
        clearBtn.classList.add("flex");
      } else {
        clearBtn.classList.add("hidden");
        clearBtn.classList.remove("flex");
      }
    }

    function highlight(idx) {
      const items = [...list.querySelectorAll("li[data-value]")];
      items.forEach((li, i) => {
        if (i === idx) li.classList.add("bg-bg-black-50");
        else li.classList.remove("bg-bg-black-50");
      });
      activeIdx = idx;
      if (idx >= 0) items[idx]?.scrollIntoView({ block: "nearest" });
    }

    function render(options) {
      activeIdx = -1;
      if (options.length === 0) {
        list.innerHTML = `<li class="px-4 py-2 text-sm italic text-txt-black-500">No results</li>`;
        return;
      }
      list.innerHTML = options.map(o =>
        `<li class="cursor-pointer truncate px-4 py-2 text-sm text-txt-black-700 hover:bg-bg-black-50" data-value="${esc(o.value)}">${esc(o.label)}</li>`
      ).join("");
      list.querySelectorAll("li[data-value]").forEach(li => {
        li.addEventListener("mousedown", e => {
          e.preventDefault();
          selected = li.dataset.value;
          input.value = _options?.find(o => o.value === selected)?.label ?? "";
          list.classList.add("hidden");
          goToCandidate(selected);
        });
      });
    }

    async function open() {
      if (!_options) {
        list.innerHTML = `<li class="px-4 py-2 text-sm italic text-txt-black-500">Loading…</li>`;
        list.classList.remove("hidden");
        try {
          await loadOptions();
        } catch(e) {
          list.innerHTML = `<li class="px-4 py-2 text-sm italic text-txt-black-500">Failed to load</li>`;
          return;
        }
      }
      const q = input.value.toLowerCase().trim();
      if (!q) {
        render(_options);
        list.classList.remove("hidden");
        return;
      }
      const tokens = q.split(/\s+/);
      render(_options.filter(o => tokens.every(tok => o.label.toLowerCase().includes(tok))));
      list.classList.remove("hidden");
    }

    function close() { list.classList.add("hidden"); activeIdx = -1; }

    input.addEventListener("input",  () => { selected = ""; open(); updateClear(); });
    input.addEventListener("focus",  open);
    input.addEventListener("blur",   () => setTimeout(close, 150));
    input.addEventListener("keydown", e => {
      const items = [...list.querySelectorAll("li[data-value]")];
      const isOpen = !list.classList.contains("hidden");
      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (!isOpen) { open(); return; }
        highlight(Math.min(activeIdx + 1, items.length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        if (!isOpen) return;
        highlight(Math.max(activeIdx - 1, 0));
      } else if (e.key === "Enter") {
        if (isOpen && activeIdx >= 0 && items[activeIdx]) {
          e.preventDefault();
          selected = items[activeIdx].dataset.value;
          input.value = _options?.find(o => o.value === selected)?.label ?? "";
          close();
          goToCandidate(selected);
        }
      } else if (e.key === "Escape") {
        close();
      }
    });
    btn.addEventListener("click",    () => { if (selected) goToCandidate(selected); else focusInputWithoutScroll(); });
    clearBtn?.addEventListener("mousedown", e => {
      e.preventDefault();
      input.value = "";
      selected = "";
      close();
      updateClear();
      focusInputWithoutScroll();
    });
    document.addEventListener("click", e => { if (!wrapper.contains(e.target)) close(); });
  }

  document.querySelectorAll(".combobox").forEach(initCombobox);

  // ── Cmd/Ctrl+K shortcut ───────────────────────────────────────────────────
  document.addEventListener("keydown", e => {
    if (e.key === "k" && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      const input = document.querySelector(".combobox-input");
      const clearBtn = document.querySelector(".combobox-clear");
      if (input) {
        input.value = "";
        clearBtn?.classList.add("hidden");
        clearBtn?.classList.remove("flex");
        input.focus({ preventScroll: true });
      }
    }
  });

  let savedScrollY = null;
  try {
    savedScrollY = sessionStorage.getItem("candidateSearchScrollY");
  } catch {}
  if (savedScrollY != null) {
    try {
      sessionStorage.removeItem("candidateSearchScrollY");
    } catch {}
    const targetScrollY = Number(savedScrollY);
    if (Number.isFinite(targetScrollY)) {
      let attempts = 0;
      const restoreScroll = () => {
        attempts += 1;
        window.scrollTo({ top: targetScrollY, left: window.scrollX });
        if (Math.abs(window.scrollY - targetScrollY) > 1 && attempts < 60) {
          requestAnimationFrame(restoreScroll);
        }
      };
      requestAnimationFrame(restoreScroll);
    }
  }

  // On slug pages, prefetch in the background so data is ready when the user searches
  if (!preloadedOptions) {
    loadOptions().catch(function() {});
  }

  // ── View count ────────────────────────────────────────────────────────────
  const vcEl = document.getElementById("cand-view-count");
  if (vcEl) {
    const { token, host } = vcEl.dataset;
    if (token && host) {
      fetch(`${host}/v0/pipes/views_by_page.json?token=${token}&page_id=/candidates`)
        .then(r => r.json())
        .then(data => {
          const views = data?.data?.[0]?.hits;
          if (views != null) vcEl.textContent = `${Number(views).toLocaleString()} views`;
        })
        .catch(() => {});
    }
  }
</script>
