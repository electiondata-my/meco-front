<script>
  const STORAGE_KEY = "meco-elections-state";

  const tabTable = document.getElementById("tab-analysis-table");
  const tabChart = document.getElementById("tab-analysis-chart");
  const viewTable = document.getElementById("analysis-table-view");
  const viewChart = document.getElementById("analysis-chart-view");
  const varDropdown = document.getElementById("analysis-var-dropdown");
  const varCurrentLabel = document.getElementById("analysis-var-current-label");

  let currentVarKey = "voter_turnout_perc";

  const activeClasses = ["border", "border-otl-gray-200", "bg-bg-dialog-active", "text-txt-black-900", "shadow-button"];
  const inactiveClasses = ["text-txt-black-500"];

  function activateTable() {
    viewTable?.classList.remove("hidden");
    viewChart?.classList.add("hidden");
    varDropdown?.classList.add("hidden");
    tabTable?.classList.add(...activeClasses);
    tabTable?.classList.remove(...inactiveClasses);
    tabChart?.classList.remove(...activeClasses);
    tabChart?.classList.add(...inactiveClasses);
  }

  function activateChart() {
    viewTable?.classList.add("hidden");
    viewChart?.classList.remove("hidden");
    varDropdown?.classList.remove("hidden");
    tabChart?.classList.add(...activeClasses);
    tabChart?.classList.remove(...inactiveClasses);
    tabTable?.classList.remove(...activeClasses);
    tabTable?.classList.add(...inactiveClasses);
  }

  tabTable?.addEventListener("click", activateTable);
  tabChart?.addEventListener("click", activateChart);

  // Update dropdown button label + checkmarks, and dispatch to React chart
  function selectVar(varKey: string) {
    currentVarKey = varKey;

    // Update displayed label from the clicked item's text
    const item = document.querySelector(`[data-var-key="${varKey}"]`);
    if (item && varCurrentLabel) {
      varCurrentLabel.textContent = item.querySelector("span")?.textContent ?? varKey;
    }

    // Update checkmarks + font weight
    document.querySelectorAll<HTMLElement>("[data-var-key]").forEach((btn) => {
      const isSelected = btn.dataset.varKey === varKey;
      btn.querySelector(".var-check")?.classList.toggle("hidden", !isSelected);
      const span = btn.querySelector("span");
      if (span) span.className = `grow truncate ${isSelected ? "font-medium" : "font-normal"}`;
    });

    document.dispatchEvent(new CustomEvent("elections-var-change", { detail: { varKey } }));
  }

  // Wire up variable item clicks
  document.querySelectorAll<HTMLElement>("[data-var-key]").forEach((btn) => {
    btn.addEventListener("click", () => selectVar(btn.dataset.varKey!));
  });

  // ── Session state: restore tab + variable + scroll across filter navigations ──
  function loadSaved() {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (Date.now() - (parsed.ts ?? 0) < 10000) return parsed;
    } catch {}
    return null;
  }

  const saved = loadSaved();

  if (saved?.tab === "chart") activateChart();

  if (saved?.varKey && saved.varKey !== "voter_turnout_perc") {
    // Update UI without dispatching (React reads sessionStorage itself on init)
    selectVar(saved.varKey);
  }

  if (saved?.scrollY) {
    requestAnimationFrame(() => window.scrollTo({ top: saved.scrollY, behavior: "instant" }));
  }

  window.addEventListener("beforeunload", () => {
    try {
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        tab: viewChart?.classList.contains("hidden") ? "table" : "chart",
        varKey: currentVarKey,
        scrollY: window.scrollY,
        ts: Date.now(),
      }));
    } catch {}
  });
</script>

