            <button
              id="tab-overview-table"
              type="button"
              class="flex h-7 items-center rounded-md px-3 text-body-sm font-medium border border-otl-gray-200 bg-bg-dialog-active text-txt-black-900 shadow-button"
            >
              {c("table") || "Table"}
            </button>
            <button
              id="tab-overview-map"
