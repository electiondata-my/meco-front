<script>
  const STORAGE_KEY = "meco-elections-state";
  if ("scrollRestoration" in history) history.scrollRestoration = "manual";

  // ── Section 1: Overview tabs (Table | Map) ──
  const tabOverviewTable = document.getElementById("tab-overview-table");
  const tabOverviewMap = document.getElementById("tab-overview-map");
  const viewOverviewTable = document.getElementById("overview-table-view");
  const viewOverviewMap = document.getElementById("overview-map-view");

  const overviewActiveClasses = ["border", "border-otl-gray-200", "bg-bg-dialog-active", "text-txt-black-900", "shadow-button"];
  const overviewInactiveClasses = ["text-txt-black-500"];

  function setOverviewTab(activeTab: Element | null) {
    viewOverviewTable?.classList.toggle("hidden", activeTab !== tabOverviewTable);
    viewOverviewMap?.classList.toggle("hidden", activeTab !== tabOverviewMap);

    [tabOverviewTable, tabOverviewMap].forEach((tab) => {
      if (tab === activeTab) {
        tab?.classList.add(...overviewActiveClasses);
        tab?.classList.remove(...overviewInactiveClasses);
      } else {
        tab?.classList.remove(...overviewActiveClasses);
        tab?.classList.add(...overviewInactiveClasses);
      }
    });

    if (activeTab === tabOverviewMap) {
      document.dispatchEvent(new CustomEvent("elections-overview-view-change", {}));
    }
  }

  tabOverviewTable?.addEventListener("click", () => setOverviewTab(tabOverviewTable));
  tabOverviewMap?.addEventListener("click", () => setOverviewTab(tabOverviewMap));

  // ── Section 3: Analysis tabs (Table | Chart | Map) ──
  const tabTable = document.getElementById("tab-analysis-table");
  const tabChart = document.getElementById("tab-analysis-chart");
  const tabMap = document.getElementById("tab-analysis-map");
  const viewTable = document.getElementById("analysis-table-view");
  const viewChart = document.getElementById("analysis-chart-view");
  const viewMap = document.getElementById("analysis-map-view");
  const varDropdown = document.getElementById("analysis-var-dropdown");
  const varCurrentLabel = document.getElementById("analysis-var-current-label");

  let currentVarKey = "voter_turnout_perc";

  const activeClasses = ["border", "border-otl-gray-200", "bg-bg-dialog-active", "text-txt-black-900", "shadow-button"];
  const inactiveClasses = ["text-txt-black-500"];

  function setAnalysisTab(activeTab: Element | null, showVar: boolean) {
    [tabTable, tabChart, tabMap].forEach((tab) => {
      if (tab === activeTab) {
        tab?.classList.add(...activeClasses);
        tab?.classList.remove(...inactiveClasses);
      } else {
        tab?.classList.remove(...activeClasses);
        tab?.classList.add(...inactiveClasses);
      }
    });
    viewTable?.classList.toggle("hidden", activeTab !== tabTable);
    viewChart?.classList.toggle("hidden", activeTab !== tabChart);
    viewMap?.classList.toggle("hidden", activeTab !== tabMap);
    varDropdown?.classList.toggle("hidden", !showVar);
  }

  function activateTable() { setAnalysisTab(tabTable, false); }
  function activateChart() { setAnalysisTab(tabChart, true); }
  function activateMap() {
    setAnalysisTab(tabMap, true);
    document.dispatchEvent(new CustomEvent("elections-analysis-view-change", {}));
  }

  tabTable?.addEventListener("click", activateTable);
  tabChart?.addEventListener("click", activateChart);
  tabMap?.addEventListener("click", activateMap);

  // Update dropdown button label + checkmarks, and dispatch to React chart
  function selectVar(varKey: string) {
    currentVarKey = varKey;

    // Update displayed label from the clicked item's text
    const item = document.querySelector(`[data-var-key="${varKey}"]`);
    if (item && varCurrentLabel) {
      varCurrentLabel.textContent = item.querySelector("span")?.textContent ?? varKey;
    }

    // Update checkmarks + font weight
    document.querySelectorAll<HTMLElement>("[data-var-key]").forEach((btn) => {
      const isSelected = btn.dataset.varKey === varKey;
      btn.querySelector(".var-check")?.classList.toggle("hidden", !isSelected);
      const span = btn.querySelector("span");
      if (span) span.className = `grow truncate ${isSelected ? "font-medium" : "font-normal"}`;
    });

    document.dispatchEvent(new CustomEvent("elections-var-change", { detail: { varKey } }));
  }

  // Wire up variable item clicks
  document.querySelectorAll<HTMLElement>("[data-var-key]").forEach((btn) => {
    btn.addEventListener("click", () => selectVar(btn.dataset.varKey!));
  });

  // ── Session state: restore tab + variable + scroll across filter navigations ──
  function loadSaved() {
    try {
      const raw = sessionStorage.getItem(STORAGE_KEY);
      if (!raw) return null;
      const parsed = JSON.parse(raw);
      if (Date.now() - (parsed.ts ?? 0) < 10000) return parsed;
    } catch {}
    return null;
  }

  function restoreSavedAnchor(savedState) {
    const anchor = savedState?.anchor;
    if (!anchor?.name || typeof anchor.offset !== "number") return;
    const target = document.querySelector(`[data-scroll-anchor="${anchor.name}"]`);
    if (!target) return;

    let attempts = 0;
    let cancelled = false;
    const cancel = () => {
      cancelled = true;
    };
    window.addEventListener("wheel", cancel, { once: true, passive: true });
    window.addEventListener("touchstart", cancel, { once: true, passive: true });
    window.addEventListener("keydown", cancel, { once: true });
    const restore = () => {
      if (cancelled) return;
      attempts += 1;
      const top = window.scrollY + target.getBoundingClientRect().top - anchor.offset;
      window.scrollTo({ top, left: window.scrollX, behavior: "instant" });
      if (attempts < 90) requestAnimationFrame(restore);
    };
    requestAnimationFrame(restore);
  }

  const saved = loadSaved();

  if (saved?.tab === "chart") activateChart();
  else if (saved?.tab === "map") activateMap();
  if (saved?.overviewTab === "map") setOverviewTab(tabOverviewMap);

  if (saved?.varKey && saved.varKey !== "voter_turnout_perc") {
    // Update UI without dispatching (React reads sessionStorage itself on init)
    selectVar(saved.varKey);
  }

  restoreSavedAnchor(saved);
  if (saved?.anchor) {
    try {
      const rest = { ...saved };
      delete rest.anchor;
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ ...rest, ts: Date.now() }));
    } catch {}
  }

  window.addEventListener("beforeunload", () => {
    try {
      const existing = loadSaved() ?? {};
      sessionStorage.setItem(STORAGE_KEY, JSON.stringify({
        ...existing,
        tab: !viewChart?.classList.contains("hidden") ? "chart" : !viewMap?.classList.contains("hidden") ? "map" : "table",
        overviewTab: viewOverviewMap?.classList.contains("hidden") ? "table" : "map",
        varKey: currentVarKey,
        ts: Date.now(),
      }));
    } catch {}
  });
</script>

