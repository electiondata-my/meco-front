            const title = e("live_voter_turnout") || "Live Voter Turnout";
            if (isMalay && title.includes("Live")) {
              const [before, after] = title.split("Live");
              return <Fragment>{before}<em>Live</em>{after}</Fragment>;
            }
            return title;
          })()}
          {asOfLabel && <span class="font-normal"> {asOfLabel}</span>}
        </h4>
        <div class="mx-auto w-full lg:w-3/4">
          <LiveTurnoutChart
            client:load
            data={liveTurnout}
            se15Annotation={se15Annotation}
            ge15Annotation={ge15Annotation}
            forecastPrefix={forecastPrefix}
          />
        </div>

        <!-- Machine-readable copy of the chart data (canvas isn't scrapeable) -->
        <table class="sr-only">
          <caption>{e("live_voter_turnout") || "Live Voter Turnout"} {asOfLabel}</caption>
          <thead>
            <tr>
              <th>{c("time") || "Time"}</th>
              {liveTurnoutSeries.map((s) => <th>{s.label}</th>)}
            </tr>
          </thead>
          <tbody>
            {liveTurnout.time.map((time, i) => (
              <tr>
                <th>{time}</th>
                {liveTurnoutSeries.map((s) => <td>{s.values[i] == null ? "" : `${s.values[i]}%`}</td>)}
              </tr>
