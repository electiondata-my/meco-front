<script define:vars={{ localePrefix, stateCode, electionName, tinybirdBaseUrl, tinybirdToken, viewsOneLabel, viewsOtherLabel, mobileElectionOptionsByState, selectElectionLabel }}>
  const ELECTIONS_STORAGE_KEY = "meco-elections-state";
  const mobileFilter = document.getElementById("mobile-filter");
  const filterOpen = document.getElementById("filter-open");
  const filterClose = document.getElementById("filter-close");
  const filterCancel = document.getElementById("filter-cancel");
  const filterBackdrop = document.getElementById("mobile-filter-backdrop");
  const mobileFilterSummary = document.getElementById("mobile-filter-summary");
  const viewsCounter = document.getElementById("views-counter");

  if (viewsCounter) {
    if (!tinybirdBaseUrl || !tinybirdToken) {
      viewsCounter.textContent = "---";
    } else {
      fetch(`${tinybirdBaseUrl}/v0/pipes/views_by_page.json?token=${tinybirdToken}&page_id=/elections`)
        .then((response) => (response.ok ? response.json() : Promise.reject()))
        .then((payload) => {
          const views = payload?.data?.[0]?.hits;
          if (typeof views !== "number") {
            viewsCounter.textContent = "---";
            return;
          }
          const formatted = views.toLocaleString("en-MY");
          viewsCounter.textContent = `${formatted} ${views === 1 ? viewsOneLabel : viewsOtherLabel}`;
        })
        .catch(() => {
          viewsCounter.textContent = "---";
        });
    }
  }

  function closeMobileFilter() {
    mobileFilter?.classList.add("hidden");
    document.body.style.overflow = "";
  }

  filterOpen?.addEventListener("click", () => {
    mobileFilter?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
  });
  filterClose?.addEventListener("click", closeMobileFilter);
  filterCancel?.addEventListener("click", closeMobileFilter);
  filterBackdrop?.addEventListener("click", closeMobileFilter);

  const mobileStateSelect = document.getElementById("mobile-state-select");
  const mobileElectionType = document.getElementById("mobile-election-type");
  const mobileElectionSelect = document.getElementById("mobile-election-select");
  const mobileElectionOptions = document.getElementById("mobile-election-options");
  const mobileElectionCurrentLabel = document.querySelector("[data-election-current-label]");
  const desktopStateCurrentFlag = document.getElementById("desktop-state-current-flag");
  const desktopStateCurrentLabel = document.getElementById("desktop-state-current-label");
  const desktopElectionCurrentLabel = document.getElementById("desktop-election-current-label");
  const desktopElectionOptions = document.getElementById("desktop-election-options");
  let desktopState = stateCode;
  let desktopElectionType = electionName.startsWith("GE") ? "parlimen" : "dun";
  let currentDesktopElection = electionName;

  function saveElectionsVisualAnchor() {
    const anchors = Array.from(document.querySelectorAll("[data-scroll-anchor]"));
    if (anchors.length === 0) return;
    const anchor = anchors.reduce((best, candidate) => {
      const candidateTop = candidate.getBoundingClientRect().top;
      const bestTop = best.getBoundingClientRect().top;
      return Math.abs(candidateTop) < Math.abs(bestTop) ? candidate : best;
    });
    try {
      const raw = sessionStorage.getItem(ELECTIONS_STORAGE_KEY);
      const existing = raw ? JSON.parse(raw) : {};
      sessionStorage.setItem(ELECTIONS_STORAGE_KEY, JSON.stringify({
        ...existing,
        anchor: {
          name: anchor.getAttribute("data-scroll-anchor"),
          offset: anchor.getBoundingClientRect().top,
        },
        ts: Date.now(),
      }));
    } catch {}
  }

  function createCheckIcon(hidden = false, attr = "data-desktop-election-check") {
    const check = document.createElementNS("http://www.w3.org/2000/svg", "svg");
    const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
    check.setAttribute(attr, "");
    check.setAttribute("viewBox", "0 0 24 24");
    check.setAttribute("fill", "currentColor");
    check.setAttribute("aria-hidden", "true");
    check.setAttribute("class", `${hidden ? "hidden " : ""}h-4 w-4 text-primary-600`);
    path.setAttribute("fill-rule", "evenodd");
    path.setAttribute("clip-rule", "evenodd");
    path.setAttribute("d", "M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.03-2.03a.75.75 0 0 0-1.06-1.06l-4.72 4.72-1.72-1.72a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l5.25-5.25Z");
    check.appendChild(path);
    return check;
  }

  function setDesktopTypeButtonState(type) {
    document.querySelectorAll("[data-desktop-type]").forEach((button) => {
      const active = button.getAttribute("data-desktop-type") === type;
      button.classList.toggle("border", active);
      button.classList.toggle("border-otl-gray-200", active);
      button.classList.toggle("bg-bg-dialog-active", active);
      button.classList.toggle("text-txt-black-900", active);
      button.classList.toggle("shadow-button", active);
      button.classList.toggle("text-txt-black-500", !active);
    });
  }

  function syncDesktopTypeAvailability(preferredType = desktopElectionType) {
    const dunButton = document.querySelector('[data-desktop-type="dun"]');
    const hasDun = (mobileElectionOptionsByState?.[desktopState]?.dun ?? []).length > 0;
    if (dunButton instanceof HTMLButtonElement) {
      dunButton.disabled = !hasDun;
      dunButton.classList.toggle("cursor-not-allowed", !hasDun);
      dunButton.classList.toggle("opacity-40", !hasDun);
    }
    desktopElectionType = preferredType === "dun" && hasDun ? "dun" : "parlimen";
    setDesktopTypeButtonState(desktopElectionType);
  }

  function setDesktopStateButtonState(nextState) {
    document.querySelectorAll("[data-desktop-state]").forEach((button) => {
      const selected = button.getAttribute("data-desktop-state") === nextState;
      const label = button.querySelector("span");
      label?.classList.toggle("font-medium", selected);
      label?.classList.toggle("font-normal", !selected);
      button.querySelector("[data-desktop-state-check]")?.classList.toggle("hidden", !selected);
    });
  }

  function populateDesktopElectionOptions(preferredElection = "") {
    if (!desktopElectionOptions) return;
    const options = mobileElectionOptionsByState?.[desktopState]?.[desktopElectionType] ?? [];
    const selectedValue = options.some((option) => option.value === preferredElection) ? preferredElection : "";
    desktopElectionOptions.replaceChildren();
    options.forEach((option) => {
      const li = document.createElement("li");
      const button = document.createElement("button");
      const label = document.createElement("span");
      const selected = option.value === selectedValue;
      button.type = "button";
      button.dataset.desktopElection = option.value;
      button.dataset.electionLabel = option.label;
      button.className = "flex w-full select-none items-center gap-2 whitespace-nowrap py-2 pl-4 pr-4 text-left text-body-sm text-txt-black-900 hover:bg-bg-black-100";
      label.className = `grow truncate ${selected ? "font-medium" : "font-normal"}`;
      label.textContent = option.label;
      button.append(label, createCheckIcon(!selected));
      li.appendChild(button);
      desktopElectionOptions.appendChild(li);
    });
    const selectedOption = options.find((option) => option.value === selectedValue);
    if (desktopElectionCurrentLabel) desktopElectionCurrentLabel.textContent = selectedOption?.label ?? selectElectionLabel;
  }

  document.querySelectorAll("[data-desktop-state]").forEach((button) => {
    button.addEventListener("click", () => {
      const nextState = button.getAttribute("data-desktop-state") ?? stateCode;
      if (nextState === desktopState) return;
      desktopState = nextState;
      const label = button.getAttribute("data-state-label") ?? desktopState;
      if (desktopStateCurrentLabel) desktopStateCurrentLabel.textContent = label;
      if (desktopStateCurrentFlag instanceof HTMLImageElement) {
        desktopStateCurrentFlag.src = `/static/images/states/${desktopState}.jpeg`;
        desktopStateCurrentFlag.alt = label;
      }
      setDesktopStateButtonState(desktopState);
      syncDesktopTypeAvailability(desktopElectionType);
      const preferred = desktopElectionType === "parlimen" ? currentDesktopElection : "";
      populateDesktopElectionOptions(preferred);
      // For GE: if the election is already resolved, navigate immediately
      if (desktopElectionType === "parlimen" && preferred) {
        const available = mobileElectionOptionsByState?.[desktopState]?.parlimen ?? [];
        if (available.some((o) => o.value === preferred)) {
          saveElectionsVisualAnchor();
          window.location.href = `${localePrefix}/elections/${desktopState}/${preferred}`;
        }
      }
    });
  });

  document.querySelectorAll("[data-desktop-type]").forEach((button) => {
    button.addEventListener("click", () => {
      if (button instanceof HTMLButtonElement && button.disabled) return;
      const nextType = button.getAttribute("data-desktop-type") || "parlimen";
      if (nextType === desktopElectionType) return;
      desktopElectionType = nextType;
      syncDesktopTypeAvailability(nextType);
      populateDesktopElectionOptions("");
    });
  });

  desktopElectionOptions?.addEventListener("click", (event) => {
    const item = event.target instanceof Element ? event.target.closest("[data-desktop-election]") : null;
    if (!(item instanceof HTMLButtonElement)) return;
    const value = item.getAttribute("data-desktop-election") ?? "";
    if (!value) return;
    currentDesktopElection = value;
    saveElectionsVisualAnchor();
    window.location.href = `${localePrefix}/elections/${desktopState}/${value}`;
  });

  function updateMobileFilterSummary() {
    if (!mobileFilterSummary) return;
    const selectedStateButton = document.querySelector("[data-mobile-state].border-primary-600");
    const stateLabel = selectedStateButton?.getAttribute("data-state-label") || "";
    const typeLabel = mobileElectionType instanceof HTMLInputElement && mobileElectionType.value === "dun"
      ? "DUN"
      : "Parlimen";
    const electionLabel = mobileElectionCurrentLabel?.textContent?.trim() || "";
    mobileFilterSummary.textContent = [stateLabel, typeLabel, electionLabel].filter(Boolean).join(" · ");
  }

  function setMobileTypeButtonState(type) {
    document.querySelectorAll("[data-mobile-type]").forEach((button) => {
      const active = button.getAttribute("data-mobile-type") === type;
      button.classList.toggle("border", active);
      button.classList.toggle("border-otl-gray-200", active);
      button.classList.toggle("bg-bg-dialog-active", active);
      button.classList.toggle("text-txt-black-900", active);
      button.classList.toggle("shadow-button", active);
      button.classList.toggle("text-txt-black-500", !active);
    });
  }

  function populateMobileElectionOptions(preferredElection = "") {
    if (!(mobileStateSelect instanceof HTMLInputElement) || !(mobileElectionType instanceof HTMLInputElement) || !(mobileElectionSelect instanceof HTMLInputElement) || !mobileElectionOptions) return;
    const state = mobileStateSelect.value || stateCode;
    const type = mobileElectionType.value || "parlimen";
    const options = mobileElectionOptionsByState?.[state]?.[type] ?? [];
    const selectedValue = options.some((option) => option.value === preferredElection)
      ? preferredElection
      : "";
    mobileElectionSelect.value = selectedValue;
    mobileElectionOptions.replaceChildren();
    options.forEach((option) => {
      const li = document.createElement("li");
      const button = document.createElement("button");
      const label = document.createElement("span");
      const check = document.createElementNS("http://www.w3.org/2000/svg", "svg");
      const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
      const selected = option.value === selectedValue;

      button.type = "button";
      button.dataset.mobileElection = option.value;
      button.dataset.electionLabel = option.label;
      button.className = "flex min-h-10 w-full select-none items-center gap-2 whitespace-nowrap py-2 pl-3 pr-3 text-left text-body-sm text-txt-black-900 hover:bg-bg-black-100";
      label.dataset.electionOptionLabel = "";
      label.className = `grow truncate ${selected ? "font-medium" : "font-normal"}`;
      label.textContent = option.label;
      check.dataset.electionCheck = "";
      check.setAttribute("viewBox", "0 0 24 24");
      check.setAttribute("fill", "currentColor");
      check.setAttribute("aria-hidden", "true");
      check.setAttribute("class", `${selected ? "" : "hidden "}h-4 w-4 text-primary-600`);
      path.setAttribute("fill-rule", "evenodd");
      path.setAttribute("clip-rule", "evenodd");
      path.setAttribute("d", "M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.03-2.03a.75.75 0 0 0-1.06-1.06l-4.72 4.72-1.72-1.72a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l5.25-5.25Z");
      check.appendChild(path);
      button.append(label, check);
      li.appendChild(button);
      mobileElectionOptions.appendChild(li);
    });
    const selectedOption = options.find((option) => option.value === selectedValue);
    if (mobileElectionCurrentLabel) mobileElectionCurrentLabel.textContent = selectedOption?.label ?? selectElectionLabel;
    updateMobileFilterSummary();
  }

  function syncMobileTypeAvailability(preferredType = "", preferredElection = "") {
    if (!(mobileStateSelect instanceof HTMLInputElement) || !(mobileElectionType instanceof HTMLInputElement)) return;
    const state = mobileStateSelect.value || stateCode;
    const dunButton = document.querySelector('[data-mobile-type="dun"]');
    const hasDun = (mobileElectionOptionsByState?.[state]?.dun ?? []).length > 0;
    if (dunButton instanceof HTMLButtonElement) dunButton.disabled = !hasDun;
    const nextType = preferredType === "dun" && hasDun ? "dun" : "parlimen";
    mobileElectionType.value = nextType;
    setMobileTypeButtonState(nextType);
    populateMobileElectionOptions(preferredElection);
  }

  document.querySelectorAll("[data-mobile-type]").forEach((button) => {
    button.addEventListener("click", () => {
      if (button instanceof HTMLButtonElement && button.disabled) return;
      const type = button.getAttribute("data-mobile-type") || "parlimen";
      if (mobileElectionType instanceof HTMLInputElement && mobileElectionType.value === type) return;
      if (mobileElectionType instanceof HTMLInputElement) mobileElectionType.value = type;
      setMobileTypeButtonState(type);
      populateMobileElectionOptions("");
    });
  });
  syncMobileTypeAvailability(electionName.startsWith("GE") ? "parlimen" : "dun", electionName);

  document.getElementById("filter-apply")?.addEventListener("click", () => {
    const state = mobileStateSelect?.value ?? stateCode;
    const elec = mobileElectionSelect?.value ?? electionName;
    if (elec) {
      saveElectionsVisualAnchor();
      window.location.href = `${localePrefix}/elections/${state}/${elec}`;
    }
  });

  mobileElectionOptions?.addEventListener("click", (event) => {
    const item = event.target instanceof Element ? event.target.closest("[data-mobile-election]") : null;
    if (!(item instanceof HTMLButtonElement) || !(mobileElectionSelect instanceof HTMLInputElement)) return;
    const value = item.getAttribute("data-mobile-election") ?? "";
    const label = item.getAttribute("data-election-label") ?? value;
    mobileElectionSelect.value = value;
    if (mobileElectionCurrentLabel) mobileElectionCurrentLabel.textContent = label;
    mobileElectionOptions.querySelectorAll("[data-mobile-election]").forEach((option) => {
      const selected = option.getAttribute("data-mobile-election") === value;
      option.querySelector("[data-election-option-label]")?.classList.toggle("font-medium", selected);
      option.querySelector("[data-election-option-label]")?.classList.toggle("font-normal", !selected);
      option.querySelector("[data-election-check]")?.classList.toggle("hidden", !selected);
    });
    mobileElectionOptions.classList.add("hidden");
    updateMobileFilterSummary();
  });

  function setMobileStateButtonState(nextState) {
    document.querySelectorAll("[data-mobile-state]").forEach((button) => {
      const selected = button.getAttribute("data-mobile-state") === nextState;
      button.classList.toggle("border-primary-600", selected);
      button.classList.toggle("bg-primary-600/10", selected);
      button.classList.toggle("text-primary-600", selected);
      button.classList.toggle("border-otl-gray-200", !selected);
      button.classList.toggle("bg-bg-white", !selected);
      button.classList.toggle("text-txt-black-700", !selected);
      button.classList.toggle("hover:border-bg-black-400", !selected);
      button.classList.toggle("hover:bg-bg-black-50", !selected);
      button.setAttribute("aria-pressed", String(selected));
    });
  }

  document.querySelectorAll("[data-mobile-state]").forEach((button) => {
    button.addEventListener("click", () => {
      const nextState = button.getAttribute("data-mobile-state") ?? stateCode;
      if (mobileStateSelect instanceof HTMLInputElement && mobileStateSelect.value === nextState) return;
      if (mobileStateSelect instanceof HTMLInputElement) mobileStateSelect.value = nextState;
      setMobileStateButtonState(nextState);
      const currentMobileType = mobileElectionType instanceof HTMLInputElement ? mobileElectionType.value : "parlimen";
      const currentMobileElec = mobileElectionSelect instanceof HTMLInputElement ? mobileElectionSelect.value : "";
      // For GE, keep the current election selected if the new state has it
      syncMobileTypeAvailability(currentMobileType, currentMobileType === "parlimen" ? currentMobileElec : "");
      updateMobileFilterSummary();
    });
  });
  setMobileStateButtonState(stateCode);

  document.querySelectorAll(".site-menu").forEach((menu) => {
    const button = menu.querySelector(".site-menu-button");
    const list = menu.querySelector(".site-menu-list");
    button?.addEventListener("click", (event) => {
      event.stopPropagation();
      document.querySelectorAll(".site-menu-list").forEach((other) => {
        if (other !== list) other.classList.add("hidden");
      });
      list?.classList.toggle("hidden");
      button.setAttribute("aria-expanded", String(!list?.classList.contains("hidden")));
    });
  });
  document.addEventListener("click", () => {
    document.querySelectorAll(".site-menu-list").forEach((list) => list.classList.add("hidden"));
    document.querySelectorAll(".site-menu-button").forEach((button) => button.setAttribute("aria-expanded", "false"));
  });

  const tableBody = document.querySelector("#analysis-table tbody");
  const tableShell = document.getElementById("analysis-table-shell");
  const tableScroll = document.getElementById("analysis-table-scroll");
  const rows = Array.from(document.querySelectorAll(".analysis-row"));
  const pagination = document.getElementById("analysis-pagination");
  const prev = document.getElementById("analysis-prev");
  const next = document.getElementById("analysis-next");
  const range = document.getElementById("analysis-page-range");
  const count = document.getElementById("analysis-page-count");
  const perPage = 12;
  let page = 1;
  let sortKey = "";
  let sortDirection = "desc";

  rows.forEach((row, index) => {
    row.setAttribute("data-original-index", String(index));
  });

  function updateTableScrollFades() {
    if (!tableShell || !tableScroll) return;
    const maxScrollLeft = tableScroll.scrollWidth - tableScroll.clientWidth;
    const hasOverflow = maxScrollLeft > 1;
    tableShell.dataset.scrollEnd = String(!hasOverflow || tableScroll.scrollLeft >= maxScrollLeft - 1);
  }

  tableScroll?.addEventListener("scroll", updateTableScrollFades, { passive: true });
  window.addEventListener("resize", updateTableScrollFades);

  function sortValue(row, key) {
    const cell = row.querySelector(`[data-sort-key="${key}"]`);
    const rawValue = cell?.getAttribute("data-sort-value") ?? "";
    return rawValue === "" ? null : Number(rawValue);
  }

  function updateSortIndicators() {
    document.querySelectorAll("[data-sort-indicator]").forEach((indicator) => {
      const key = indicator.getAttribute("data-sort-indicator");
      indicator.setAttribute("data-sort-state", key === sortKey && sortDirection ? sortDirection : "none");
    });
  }

  function sortRows(key) {
    if (!tableBody) return;
    if (sortKey === key) {
      if (sortDirection === "desc") sortDirection = "asc";
      else if (sortDirection === "asc") sortDirection = "";
      else sortDirection = "desc";
    } else {
      sortKey = key;
      sortDirection = "desc";
    }

    if (!sortDirection) {
      sortKey = "";
      rows.sort((a, b) => Number(a.getAttribute("data-original-index")) - Number(b.getAttribute("data-original-index")));
    } else {
      rows.sort((a, b) => {
        const aValue = sortValue(a, key);
        const bValue = sortValue(b, key);
        if (aValue === null && bValue === null) {
          return Number(a.getAttribute("data-original-index")) - Number(b.getAttribute("data-original-index"));
        }
        if (aValue === null) return 1;
        if (bValue === null) return -1;
        const delta = aValue - bValue;
        if (delta === 0) {
          return Number(a.getAttribute("data-original-index")) - Number(b.getAttribute("data-original-index"));
        }
        return sortDirection === "asc" ? delta : -delta;
      });
    }

    rows.forEach((row) => tableBody.appendChild(row));
    page = 1;
    updateSortIndicators();
    renderAnalysisPage();
  }

  document.querySelectorAll("[data-sort-key]").forEach((button) => {
    if (!(button instanceof HTMLButtonElement)) return;
    button.addEventListener("click", () => {
      const key = button.getAttribute("data-sort-key");
      if (key) sortRows(key);
    });
  });

  function renderAnalysisPage() {
    const totalPages = Math.max(1, Math.ceil(rows.length / perPage));
    page = Math.min(Math.max(page, 1), totalPages);
    const start = (page - 1) * perPage;
    const end = Math.min(start + perPage, rows.length);
    rows.forEach((row, index) => {
      row.classList.toggle("hidden", index < start || index >= end);
    });
    if (range) range.textContent = `${start + 1}-${end} / ${rows.length}`;
    if (count) count.textContent = `${page} of ${totalPages}`;
    if (prev instanceof HTMLButtonElement) prev.disabled = page === 1;
    if (next instanceof HTMLButtonElement) next.disabled = page === totalPages;
    pagination?.classList.toggle("hidden", rows.length <= perPage);
    pagination?.classList.toggle("flex", rows.length > perPage);
    updateTableScrollFades();
  }

  prev?.addEventListener("click", () => {
    page -= 1;
    renderAnalysisPage();
  });
  next?.addEventListener("click", () => {
    page += 1;
    renderAnalysisPage();
  });
  renderAnalysisPage();
</script>
