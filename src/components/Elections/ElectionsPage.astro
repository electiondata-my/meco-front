---
import Layout from "@src/components/Layout/index.astro";
import BallotSeat from "./BallotSeat";
import ElectionOverviewIsland from "./ElectionOverviewTable";
import ElectionsAnalysisChart from "./ElectionsAnalysisChart";
import ElectionsAnalysisMap from "./ElectionsAnalysisMap";
import ElectionsMap from "./ElectionsMap";
import LiveTurnoutChart from "./LiveTurnoutChart";
import { getTranslations, t } from "@i18n/index";
import { CountryAndStates, MALAYSIA, SEMENANJUNG, STATES } from "@src/lib/constants";
import type { ElectionParty } from "./ElectionOverviewTable";

type ElectionEntry = { state: string; election: string; date: string };

type OverallSeat = {
  seat: string;
  date: string;
  party: string;
  party_uid?: string;
  name: string;
  majority: number | null;
  majority_perc: number | null;
  n_candidates?: number;
  voters_total?: number;
  voter_turnout?: number;
  voter_turnout_perc?: number;
  votes_rejected?: number;
  votes_rejected_perc?: number;
  votes_valid?: number;
  party_lost?: string[];
};

interface Props {
  stateCode: string;
  electionName: string;
  seats: OverallSeat[];
  table: ElectionParty[];
  datesRaw: ElectionEntry[];
}

const { stateCode, electionName, seats, table, datesRaw } = Astro.props;
const locale = Astro.currentLocale ?? "en-GB";
const isMalay = locale.startsWith("ms");
const apiBase = import.meta.env.PUBLIC_API_URL_R2 ?? "";
const tinybirdBaseUrl = import.meta.env.PUBLIC_API_URL_TB ?? "";
const tinybirdToken = import.meta.env.PUBLIC_TINYBIRD_TOKEN ?? "";
const i18n = await getTranslations(locale, ["common", "elections"]);
const c = (key: string) => t(i18n.common ?? {}, key);
const e = (key: string) => t(i18n.elections ?? {}, key);
const localePrefix = isMalay ? "/ms-MY" : "";

const isGE = electionName.startsWith("GE");

const electionSlug = electionName.toLowerCase();
const filePrefix = isGE ? electionSlug : `${stateCode}_${electionSlug}`;
const mapUrl = `${apiBase}/maps/${filePrefix}_choropleth.geojson`;
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN ?? "";
const EAST_MALAYSIA = ["Sabah", "Sarawak", "W.P. Labuan"];
const mapStateFilter = (isGE && stateCode !== "mys" && stateCode !== "smj")
  ? CountryAndStates[stateCode]
  : undefined;
const mapExcludeStates = (isGE && stateCode === "smj") ? EAST_MALAYSIA : undefined;

// Build navigation data from the dates prop (no extra fetch)
const datesMap = datesRaw.reduce(
  (acc, e) => {
    (acc[e.state] ??= []).push(e);
    return acc;
  },
  {} as Record<string, ElectionEntry[]>,
);

const NON_SE_STATES = ["mys", "smj", "kul", "lbn", "pjy"];
const priorityStateKeys = ["mys", "smj", "swk", "sbh"];
const allStateOptions = [MALAYSIA, SEMENANJUNG, ...STATES].map((s) => ({
  value: s.key,
  label: s.name,
}));
const stateOptions = [
  ...priorityStateKeys
    .map((key) => allStateOptions.find((option) => option.value === key))
    .filter((option): option is (typeof allStateOptions)[number] => Boolean(option)),
  ...allStateOptions
    .filter((option) => !priorityStateKeys.includes(option.value))
    .sort((a, b) => a.label.localeCompare(b.label)),
];
const electionOptionLabel = (election: string, date: string) => {
  const displayElection = isMalay
    ? election.replace(/^GE/, "PRU").replace(/^SE/, "PRN")
    : election;
  const year = date ? new Date(date).getFullYear() : null;
  return year ? `${displayElection} (${year})` : displayElection;
};

const geOptions = (datesMap["Malaysia"] ?? [])
  .map((e) => ({
    value: e.election,
    label: electionOptionLabel(e.election, e.date),
    date: e.date,
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const stateName = CountryAndStates[stateCode] ?? stateCode;
const seOptions = NON_SE_STATES.includes(stateCode)
  ? []
  : (datesMap[stateName] ?? [])
      .filter((e) => !e.election.startsWith("GE"))
      .map((e) => ({ value: e.election, label: electionOptionLabel(e.election, e.date), date: e.date }))
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const currentElectionOptions = isGE ? geOptions : seOptions;
const stateLinkOptions = stateOptions.map((o) => {
  const targetStateName = CountryAndStates[o.value] ?? o.label;
  const targetSe = NON_SE_STATES.includes(o.value)
    ? ""
    : (datesMap[targetStateName] ?? [])
        .filter((entry) => !entry.election.startsWith("GE"))
        .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())[0]?.election;
  return {
    ...o,
    href: `${localePrefix}/elections/${o.value}/${isGE ? electionName : (targetSe || "GE-15")}`,
  };
});
const electionLinkOptions = currentElectionOptions.map((o) => ({
  ...o,
  href: `${localePrefix}/elections/${stateCode}/${o.value}`,
}));
const mobileElectionOptionsByState = Object.fromEntries(
  stateOptions.map((o) => {
    const targetStateName = CountryAndStates[o.value] ?? o.label;
    const dunOptions = NON_SE_STATES.includes(o.value)
      ? []
      : (datesMap[targetStateName] ?? [])
          .filter((entry) => !entry.election.startsWith("GE"))
          .map((entry) => ({
            value: entry.election,
            label: electionOptionLabel(entry.election, entry.date),
          }))
          .sort((a, b) => Number(b.value.match(/\d+/)?.[0] ?? 0) - Number(a.value.match(/\d+/)?.[0] ?? 0));
    const stateGeEntries = (datesMap[targetStateName] ?? [])
      .filter((entry) => entry.election.startsWith("GE"))
      .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
    const parlimenOptions = stateGeEntries.length > 0
      ? stateGeEntries.map((entry) => ({ value: entry.election, label: electionOptionLabel(entry.election, entry.date) }))
      : geOptions.map((entry) => ({ value: entry.value, label: entry.label }));
    return [
      o.value,
      {
        parlimen: parlimenOptions,
        dun: dunOptions,
      },
    ];
  }),
);
const selectedStateOption = stateLinkOptions.find((o) => o.value === stateCode) ?? stateLinkOptions[0];
const selectedElectionOption = electionLinkOptions.find((o) => o.value === electionName) ?? electionLinkOptions[0];
const selectElectionLabel = e("select_election") !== "select_election" ? e("select_election") : "Select election";
const viewsOneLabel = c("views_one") || "view";
const viewsOtherLabel = c("views_other") || "views";
const compactStateLabel = (state: string) =>
  ({
    "W.P. Kuala Lumpur": "KL",
    "W.P. Putrajaya": "Putrajaya",
    "W.P. Labuan": "Labuan",
    "Negeri Sembilan": "N9",
    "Pulau Pinang": "P. Pinang",
  }[state] ?? state);

// Analysis table rows (from seats prop)
const analysisRows = seats.map((s) => {
  const [seat, ...stParts] = s.seat.split(", ");
  const state = stParts.join(", ");
  return {
    seat,
    state,
    stateDisplay: compactStateLabel(state),
    majority: s.majority,
    majority_perc: s.majority_perc,
    n_candidates: s.n_candidates,
    voters_total: s.voters_total,
    voter_turnout: s.voter_turnout,
    voter_turnout_perc: s.voter_turnout_perc,
    votes_rejected: s.votes_rejected,
    votes_rejected_perc: s.votes_rejected_perc,
  };
});

const electionDisplay = isMalay
  ? electionName.replace(/^GE/, "PRU").replace(/^SE/, "PRN")
  : electionName;
const electionYear = selectedElectionOption?.date
  ? String(new Date(selectedElectionOption.date).getFullYear())
  : (electionName.match(/\d+/)?.[0] ?? electionName);
const electionTypeLabel =
  (isGE ? e("general_election") : e("state_election")) !== (isGE ? "general_election" : "state_election")
    ? (isGE ? e("general_election") : e("state_election"))
    : isGE
      ? (isMalay ? "Pilihan Raya Umum" : "General Election")
      : (isMalay ? "Pilihan Raya Negeri" : "State Election");
const sectionTitle = isMalay
  ? `${stateName}: ${electionTypeLabel} ${electionYear}`
  : `${stateName}: ${electionYear} ${electionTypeLabel}`;
const titleCaseSectionTitle = sectionTitle.replace(/\p{L}[\p{L}'-]*/gu, (word) =>
  word.length <= 2 ? word : `${word[0].toLocaleUpperCase(locale)}${word.slice(1).toLocaleLowerCase(locale)}`,
);

// Title format: "GE-15 (Malaysia) | ElectionData.MY"
const pageTitle = `${electionDisplay} (${stateName}) | ElectionData.MY`;

// Johor SE-16 results are still being announced — surface the undeclared seats as a
// row in the overview table. The row self-hides once every seat is called.
const pendingLabel = stateCode === "jhr" && electionName === "SE-16" ? "TBC" : undefined;

// Live voter turnout section (Johor SE-16 only).
// Disabled: SE-16 polling has closed, awaiting results. To re-enable next election:
//   const showLiveTurnout = stateCode === "<state>" && electionName === "<election>";
const showLiveTurnout = false;
const liveTurnoutUrl = `${apiBase}/elections/live_turnout_jhr_se16.json`;
const se15Annotation = isMalay ? "PRN-15 (BN mng)" : "SE-15 (BN win)";
const ge15Annotation = isMalay ? "PRU-15 (PH mng)" : "GE-15 (PH win)";
const forecastPrefix = isMalay ? "PRN-16 (unjuran)" : "SE-16 (forecast)";
const asOfPrefix = isMalay ? "setakat" : "as of";

// Fetch live turnout at build time so the figures are baked into the static HTML
// (scrapeable, and refreshed on each surgical rebuild).
type LiveTurnout = {
  time: string[];
  se15: (number | null)[];
  ge15: (number | null)[];
  se16: (number | null)[];
  se16_forecast: (number | null)[];
};
let liveTurnout: LiveTurnout | null = null;
if (showLiveTurnout) {
  try {
    liveTurnout = await fetch(liveTurnoutUrl).then((r) => r.json());
  } catch {
    liveTurnout = null;
  }
}
const lastIdx = (arr: (number | null)[]) => {
  for (let i = arr.length - 1; i >= 0; i--) if (arr[i] != null) return i;
  return -1;
};
let asOfLabel = "";
if (liveTurnout) {
  const idx = lastIdx(liveTurnout.se16);
  if (idx >= 0) {
    const time = liveTurnout.time[idx];
    asOfLabel = `(${asOfPrefix} ${time})`;
  }
}
const liveTurnoutSeries = liveTurnout
  ? [
      { label: ge15Annotation, values: liveTurnout.ge15 },
      { label: se15Annotation, values: liveTurnout.se15 },
      { label: "SE-16", values: liveTurnout.se16 },
      { label: forecastPrefix, values: liveTurnout.se16_forecast },
    ]
  : [];

function numFmt(n: number | null | undefined, dp = 0): string {
  if (n == null) return "—";
  return n.toLocaleString("en-MY", { minimumFractionDigits: dp, maximumFractionDigits: dp });
}

// Pinned totals row. Every column is a plain sum of the seat rows, except the two
// percentages, which are re-derived from the summed numerators/denominators (averaging
// seat-level percentages would weight a 20k-voter seat the same as a 150k-voter one).
// Majority has no meaning in aggregate, so both majority columns stay blank.
const sumOf = (pick: (seat: OverallSeat) => number | null | undefined) =>
  seats.reduce((total, seat) => total + (pick(seat) ?? 0), 0);
const totalsVotesValid = sumOf((s) => s.votes_valid);
const totals = {
  n_candidates: sumOf((s) => s.n_candidates),
  voters_total: sumOf((s) => s.voters_total),
  voter_turnout: sumOf((s) => s.voter_turnout),
  votes_rejected: sumOf((s) => s.votes_rejected),
};
const totalsTurnoutPerc = totals.voters_total ? (totals.voter_turnout / totals.voters_total) * 100 : null;
const totalsRejectedPerc = totalsVotesValid ? (totals.votes_rejected / totalsVotesValid) * 100 : null;

const analysisColumnSpecs = [
  {
    key: "seat",
    label: c("constituency") || "Constituency",
    mobileWidthCh: 20,
    widthCh: Math.max(c("constituency").length || 12, ...analysisRows.map((row) => row.seat.length)) + 3,
  },
  ...(stateCode === "mys"
    ? [{
        key: "state",
        label: c("state") || "State",
        mobileHidden: true,
        widthCh: Math.max((c("state") || "State").length, ...analysisRows.map((row) => row.stateDisplay.length)) + 4,
      }]
    : []),
  {
    key: "n_candidates",
    label: c("n_candidates") || "Candidates",
    widthCh: Math.max((c("n_candidates") || "Candidates").length + 3, numFmt(totals.n_candidates).length, ...analysisRows.map((row) => numFmt(row.n_candidates).length)) + 5,
  },
  {
    key: "voters_total",
    label: c("voters_total") || "Voters",
    widthCh: Math.max((c("voters_total") || "Voters").length + 3, numFmt(totals.voters_total).length, ...analysisRows.map((row) => numFmt(row.voters_total).length)) + 5,
  },
  {
    key: "voter_turnout",
    label: c("voter_turnout") || "Turnout",
    widthCh: Math.max((c("voter_turnout") || "Turnout").length + 3, numFmt(totals.voter_turnout).length, ...analysisRows.map((row) => numFmt(row.voter_turnout).length)) + 5,
  },
  {
    key: "voter_turnout_perc",
    label: c("voter_turnout_perc") || "Turnout %",
    widthCh: Math.max((c("voter_turnout_perc") || "Turnout %").length + 3, ...analysisRows.map((row) => numFmt(row.voter_turnout_perc, 1).length)) + 5,
  },
  {
    key: "majority",
    label: c("majority") || "Majority",
    widthCh: Math.max((c("majority") || "Majority").length + 3, ...analysisRows.map((row) => numFmt(row.majority).length)) + 5,
  },
  {
    key: "majority_perc",
    label: c("majority_perc") || "Majority %",
    widthCh: Math.max((c("majority_perc") || "Majority %").length + 3, ...analysisRows.map((row) => numFmt(row.majority_perc, 1).length)) + 5,
  },
  {
    key: "votes_rejected",
    label: c("rejected_votes") || "Rejected",
    widthCh: Math.max((c("rejected_votes") || "Rejected").length + 3, numFmt(totals.votes_rejected).length, ...analysisRows.map((row) => numFmt(row.votes_rejected).length)) + 5,
  },
  {
    key: "votes_rejected_perc",
    label: c("rejected_votes_perc") || "Rejected %",
    widthCh: Math.max((c("rejected_votes_perc") || "Rejected %").length + 3, ...analysisRows.map((row) => numFmt(row.votes_rejected_perc, 1).length)) + 5,
  },
];
const analysisTableMinWidth = `${analysisColumnSpecs.reduce((sum, column) => sum + column.widthCh, 0)}ch`;
const analysisTableMobileMinWidth = `${analysisColumnSpecs.reduce((sum, column) => sum + (column.mobileHidden ? 0 : column.widthCh), 0)}ch`;

---

<Layout title={pageTitle} description={e("hero.description")}>
  <!-- Hero -->
  <section class="w-full bg-gradient-radial from-bg-danger-100 to-bg-white">
    <div class="mx-auto flex max-w-[727px] flex-col items-center justify-center gap-4 px-4 pb-8 pt-16 md:px-6 lg:gap-6">
      <h1 class="text-center font-heading text-heading-sm font-semibold text-txt-black-900 lg:text-heading-md">
        {e("hero.header") || "Elections Explorer"}
      </h1>
      {e("hero.description") !== "hero.description" && (
        <p class="w-full text-center text-body-sm text-txt-black-700 lg:text-body-md">
          {e("hero.description")}
        </p>
      )}
      <p class="flex gap-0.5 text-body-sm text-txt-black-500">
        <svg class="h-4.5 w-4.5 self-center" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <path d="M10 12.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z" />
          <path fill-rule="evenodd" d="M.664 10.59a1.651 1.651 0 0 1 0-1.18C1.856 6.496 5.19 3.75 10 3.75s8.144 2.746 9.336 5.66c.16.39.16.78 0 1.18C18.144 13.504 14.81 16.25 10 16.25S1.856 13.504.664 10.59ZM14 10a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" clip-rule="evenodd" />
        </svg>
        <span id="views-counter">...</span>
      </p>
    </div>
  </section>

  <!-- Navigation controls -->
  <div class="mx-auto grid w-full grid-cols-4 gap-4.5 px-4.5 md:grid-cols-8 md:gap-6 md:px-6 lg:sticky lg:top-16 lg:z-30 lg:grid-cols-12 lg:border lg:border-transparent lg:bg-bg-white lg:py-2">
    <!-- Mobile: filter button -->
    <div class="fixed bottom-4 right-3 z-20 lg:hidden">
      <button
        id="filter-open"
        class="flex items-center gap-2 rounded-full border border-otl-gray-200 bg-bg-white px-4 py-2 text-body-sm font-medium text-txt-black-700 shadow-md"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
        </svg>
        {c("filters") || "Filters"}
      </button>
    </div>

    <!-- Desktop: sticky filter bar -->
    <div class="col-span-full mx-auto hidden w-full max-w-screen-xl items-center justify-center gap-2 lg:flex">
      <!-- State dropdown -->
      <div class="site-menu relative w-fit">
        <button
          type="button"
          class="site-menu-button flex select-none items-center gap-1.5 rounded-md border border-otl-gray-200 bg-bg-white px-3 py-1.5 text-start text-body-sm font-medium text-txt-black-900 shadow-button outline-none hover:border-bg-black-400 active:bg-bg-black-100"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <img id="desktop-state-current-flag" src={`/static/images/states/${selectedStateOption.value}.jpeg`} width="20" height="12" alt={selectedStateOption.label} class="self-center" />
          <span id="desktop-state-current-label" class="grow truncate">{selectedStateOption.label}</span>
          <svg class="-mx-[5px] h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        </button>
        <ul class="site-menu-list absolute left-0 top-full z-50 mt-1 hidden max-h-60 min-w-full overflow-y-auto rounded-md bg-bg-white text-txt-black-900 shadow-floating ring-1 ring-otl-gray-200 ring-opacity-5">
          {stateLinkOptions.map((o) => (
            <li>
              <button type="button" data-desktop-state={o.value} data-state-label={o.label} class="flex w-full select-none items-center gap-2 whitespace-nowrap py-2 pl-4 pr-4 text-left text-body-sm text-txt-black-900 hover:bg-bg-black-100">
                <img src={`/static/images/states/${o.value}.jpeg`} width="20" height="12" alt={o.label} />
                <span class:list={["grow truncate", o.value === stateCode ? "font-medium" : "font-normal"]}>{o.label}</span>
                {o.value === stateCode && (
                  <svg data-desktop-state-check class="h-4 w-4 text-primary-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.03-2.03a.75.75 0 0 0-1.06-1.06l-4.72 4.72-1.72-1.72a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l5.25-5.25Z" clip-rule="evenodd" />
                  </svg>
                )}
                {o.value !== stateCode && (
                  <svg data-desktop-state-check class="hidden h-4 w-4 text-primary-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M2.25 12c0-5.385 4.365-9.75 9.75-9.75s9.75 4.365 9.75 9.75-4.365 9.75-9.75 9.75S2.25 17.385 2.25 12Zm14.03-2.03a.75.75 0 0 0-1.06-1.06l-4.72 4.72-1.72-1.72a.75.75 0 0 0-1.06 1.06l2.25 2.25a.75.75 0 0 0 1.06 0l5.25-5.25Z" clip-rule="evenodd" />
                  </svg>
                )}
              </button>
            </li>
          ))}
        </ul>
      </div>

      <!-- Parlimen / DUN tabs -->
      <div class="flex h-8 items-center rounded-lg bg-bg-washed p-0">
        <button
          type="button"
          data-desktop-type="parlimen"
          class:list={[
            "flex h-8 min-h-8 items-center justify-center rounded-md px-2.5 py-1.5 text-body-sm font-medium no-underline transition-all",
            isGE
              ? "border border-otl-gray-200 bg-bg-dialog-active text-txt-black-900 shadow-button"
              : "text-txt-black-500",
          ]}
        >
          {c("parlimen") || "Parlimen"}
        </button>
        {NON_SE_STATES.includes(stateCode) ? (
          <button type="button" data-desktop-type="dun" disabled class="flex h-8 min-h-8 cursor-not-allowed items-center justify-center rounded-md px-2.5 py-1.5 text-body-sm font-medium text-txt-black-500 opacity-40">
            {c("dun") || "DUN"}
          </button>
        ) : (
          <button
            type="button"
            data-desktop-type="dun"
            class:list={[
              "flex h-8 min-h-8 items-center justify-center rounded-md px-2.5 py-1.5 text-body-sm font-medium no-underline transition-all",
              !isGE
                ? "border border-otl-gray-200 bg-bg-dialog-active text-txt-black-900 shadow-button"
                : "text-txt-black-500",
            ]}
          >
            {c("dun") || "DUN"}
          </button>
        )}
      </div>

      <!-- Election dropdown -->
      <div class="site-menu relative w-fit">
        <button
          type="button"
          class="site-menu-button flex select-none items-center gap-1.5 rounded-md border border-otl-gray-200 bg-bg-white px-3 py-1.5 text-start text-body-sm font-medium text-txt-black-900 shadow-button outline-none hover:border-bg-black-400 active:bg-bg-black-100"
          aria-haspopup="menu"
          aria-expanded="false"
        >
          <span id="desktop-election-current-label" class="grow truncate">{selectedElectionOption?.label ?? selectElectionLabel}</span>
          <svg class="-mx-[5px] h-5 w-5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
